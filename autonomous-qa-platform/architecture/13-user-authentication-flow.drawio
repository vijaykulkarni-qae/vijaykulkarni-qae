<mxfile host="app.diagrams.net" modified="2025-12-12T20:30:00.000Z" agent="Autonomous QA - Authentication" version="22.1.0">
  <diagram name="User Authentication & Authorization" id="auth-flow">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <mxCell id="title-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a237e;strokeColor=#0d47a1;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="title" value="Autonomous QA - User Authentication &amp; Authorization (JWT + bcrypt + RBAC)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="300" y="30" width="1200" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="subtitle" value="Register | Login | JWT Token | Protected Routes | Role-Based Access Control" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="500" y="60" width="800" height="20" as="geometry" />
        </mxCell>
        
        <!-- Registration -->
        <mxCell id="section1" value="═══ FLOW 1: User Registration ═══" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#4caf50;" vertex="1" parent="1">
          <mxGeometry x="700" y="110" width="400" height="25" as="geometry" />
        </mxCell>
        
        <mxCell id="lane-register" value="POST /api/auth/register" style="swimlane;startSize=30;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="1720" height="220" as="geometry" />
        </mxCell>
        
        <mxCell id="reg-request" value="Request:&#xa;{&#xa;  username,&#xa;  email,&#xa;  password&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-register">
          <mxGeometry x="80" y="50" width="90" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="reg-validate" value="1. Validate Input:&#xa;• Email format&#xa;• Password length &gt;= 8&#xa;• Username unique&#xa;• Zod schema" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=7;shadow=1;" vertex="1" parent="lane-register">
          <mxGeometry x="210" y="55" width="110" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="reg-check-exists" value="2. Check Existing:&#xa;SELECT * FROM users&#xa;WHERE email = email&#xa;&#xa;If exists: 409 Conflict" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=6.5;shadow=1;" vertex="1" parent="lane-register">
          <mxGeometry x="360" y="50" width="110" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="reg-hash" value="3. Hash Password:&#xa;bcrypt.hash(&#xa;  password,&#xa;  10 // salt rounds&#xa;)&#xa;&#xa;Cost: ~100ms&#xa;Result: 60-char hash" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=6.5;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-register">
          <mxGeometry x="510" y="45" width="110" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="reg-create" value="4. CREATE User:&#xa;INSERT INTO users&#xa;{&#xa;  id: cuid(),&#xa;  username,&#xa;  email,&#xa;  password: hashedPassword,&#xa;  role: 'user',&#xa;  createdAt: NOW()&#xa;}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=6.5;shadow=1;" vertex="1" parent="lane-register">
          <mxGeometry x="660" y="45" width="120" height="95" as="geometry" />
        </mxCell>
        
        <mxCell id="reg-token" value="5. Generate JWT:&#xa;jwt.sign({&#xa;  userId,&#xa;  email,&#xa;  role&#xa;}, SECRET, {&#xa;  expiresIn: '7d'&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=6.5;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-register">
          <mxGeometry x="820" y="55" width="110" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="reg-response" value="6. Response:&#xa;201 Created&#xa;{&#xa;  user: {id, username, email, role},&#xa;  token: 'eyJhbGc...'&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-register">
          <mxGeometry x="970" y="60" width="140" height="70" as="geometry" />
        </mxCell>
        
        <!-- Login -->
        <mxCell id="section2" value="═══ FLOW 2: User Login ═══" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#2196f3;" vertex="1" parent="1">
          <mxGeometry x="700" y="390" width="400" height="25" as="geometry" />
        </mxCell>
        
        <mxCell id="lane-login" value="POST /api/auth/login" style="swimlane;startSize=30;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="1720" height="200" as="geometry" />
        </mxCell>
        
        <mxCell id="login-request" value="Request:&#xa;{&#xa;  email,&#xa;  password&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-login">
          <mxGeometry x="980" y="50" width="90" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="login-query" value="1. Query User:&#xa;SELECT * FROM users&#xa;WHERE email = email" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-login">
          <mxGeometry x="1110" y="50" width="110" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="login-check-exists" value="User&#xa;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-login">
          <mxGeometry x="1260" y="55" width="80" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="login-not-found" value="401 Unauthorized&#xa;'Invalid credentials'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-login">
          <mxGeometry x="1250" y="10" width="100" height="45" as="geometry" />
        </mxCell>
        
        <mxCell id="login-verify" value="2. Verify Password:&#xa;bcrypt.compare(&#xa;  password,&#xa;  user.password&#xa;)&#xa;&#xa;Returns: boolean" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=6.5;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-login">
          <mxGeometry x="1380" y="50" width="110" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="login-check-pass" value="Password&#xa;match?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-login">
          <mxGeometry x="1530" y="55" width="80" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="login-fail-pass" value="401 Unauthorized&#xa;'Invalid credentials'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-login">
          <mxGeometry x="1520" y="10" width="100" height="45" as="geometry" />
        </mxCell>
        
        <mxCell id="login-token" value="3. Generate JWT:&#xa;jwt.sign({&#xa;  userId, email, role&#xa;}, SECRET)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-login">
          <mxGeometry x="1395" y="140" width="100" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="login-response" value="4. Response:&#xa;200 OK&#xa;{user, token}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-login">
          <mxGeometry x="1535" y="145" width="90" height="45" as="geometry" />
        </mxCell>
        
        <!-- Protected Route -->
        <mxCell id="section3" value="═══ FLOW 3: Protected Route Access ═══" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#ff9800;" vertex="1" parent="1">
          <mxGeometry x="700" y="650" width="400" height="25" as="geometry" />
        </mxCell>
        
        <mxCell id="lane-protected" value="GET /api/flows (Protected with authMiddleware)" style="swimlane;startSize=30;fillColor=#fff3e0;strokeColor=#e65100;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="1720" height="240" as="geometry" />
        </mxCell>
        
        <mxCell id="prot-request" value="Request:&#xa;GET /api/flows&#xa;Headers: {&#xa;  Authorization:&#xa;  'Bearer eyJhbGc...'&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-protected">
          <mxGeometry x="80" y="50" width="110" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="prot-middleware" value="authMiddleware.js&#xa;Intercepts request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=8;fontStyle=1;shadow=1;" vertex="1" parent="lane-protected">
          <mxGeometry x="230" y="65" width="100" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="prot-extract" value="1. Extract Token:&#xa;token = req.headers&#xa;  .authorization&#xa;  .split(' ')[1]&#xa;&#xa;Check: starts with 'Bearer'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=6.5;shadow=1;" vertex="1" parent="lane-protected">
          <mxGeometry x="370" y="50" width="120" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="prot-verify" value="2. Verify JWT:&#xa;jwt.verify(&#xa;  token,&#xa;  SECRET&#xa;)&#xa;&#xa;Returns: payload&#xa;or throws error" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=6.5;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-protected">
          <mxGeometry x="530" y="50" width="100" height="85" as="geometry" />
        </mxCell>
        
        <mxCell id="prot-check-valid" value="Token&#xa;valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-protected">
          <mxGeometry x="675" y="60" width="80" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="prot-invalid" value="401 Unauthorized&#xa;'Invalid/expired token'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-protected">
          <mxGeometry x="665" y="10" width="100" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="prot-attach" value="3. Attach User to Request:&#xa;req.user = {&#xa;  userId,&#xa;  email,&#xa;  role&#xa;}&#xa;&#xa;next() // Continue to route" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=6.5;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-protected">
          <mxGeometry x="800" y="50" width="130" height="85" as="geometry" />
        </mxCell>
        
        <mxCell id="prot-route" value="4. Route Handler:&#xa;GET /api/flows&#xa;&#xa;Access req.user.userId&#xa;to filter data" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#90caf9;strokeColor=#1565c0;fontSize=7;shadow=1;" vertex="1" parent="lane-protected">
          <mxGeometry x="970" y="60" width="120" height="65" as="geometry" />
        </mxCell>
        
        <mxCell id="prot-response" value="5. Response:&#xa;200 OK&#xa;{flows: [...]}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-protected">
          <mxGeometry x="1130" y="70" width="90" height="50" as="geometry" />
        </mxCell>
        
        <!-- RBAC -->
        <mxCell id="section4" value="═══ FLOW 4: Role-Based Access Control (RBAC) ═══" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#9c27b0;" vertex="1" parent="1">
          <mxGeometry x="700" y="950" width="400" height="25" as="geometry" />
        </mxCell>
        
        <mxCell id="lane-rbac" value="requireRole('admin') Middleware" style="swimlane;startSize=30;fillColor=#f3e5f5;strokeColor=#4a148c;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="990" width="1720" height="200" as="geometry" />
        </mxCell>
        
        <mxCell id="rbac-request" value="DELETE /api/users/:id&#xa;(Admin only)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-rbac">
          <mxGeometry x="1140" y="50" width="90" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="rbac-auth" value="1. Pass authMiddleware:&#xa;req.user attached" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=7;shadow=1;" vertex="1" parent="lane-rbac">
          <mxGeometry x="1270" y="55" width="100" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="rbac-check-role" value="2. requireRole Middleware:&#xa;req.user.role == 'admin'?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ba68c8;strokeColor=#7b1fa2;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-rbac">
          <mxGeometry x="1415" y="50" width="110" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="rbac-forbidden" value="403 Forbidden&#xa;'Admin role required'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-rbac">
          <mxGeometry x="1420" y="5" width="100" height="45" as="geometry" />
        </mxCell>
        
        <mxCell id="rbac-allow" value="3. Allow Access:&#xa;next()&#xa;Execute route handler" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-rbac">
          <mxGeometry x="1570" y="60" width="100" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="rbac-roles" value="Available Roles:&#xa;• user (default)&#xa;• admin&#xa;• viewer (read-only)&#xa;• executor (run tests only)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#4a148c;fontSize=7;align=left;shadow=1;" vertex="1" parent="lane-rbac">
          <mxGeometry x="80" y="55" width="150" height="70" as="geometry" />
        </mxCell>
        
        <!-- JWT Structure -->
        <mxCell id="lane-jwt" value="JWT Token Structure (Base64 Encoded)" style="swimlane;startSize=30;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1210" width="1720" height="180" as="geometry" />
        </mxCell>
        
        <mxCell id="jwt-header" value="Header:&#xa;{&#xa;  alg: 'HS256',&#xa;  typ: 'JWT'&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=7;align=left;shadow=1;" vertex="1" parent="lane-jwt">
          <mxGeometry x="80" y="50" width="100" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="jwt-payload" value="Payload:&#xa;{&#xa;  userId: 'clfx...',&#xa;  email: 'user@example.com',&#xa;  role: 'admin',&#xa;  iat: 1702377600,&#xa;  exp: 1702982400&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#a5d6a7;strokeColor=#2e7d32;fontSize=6.5;align=left;shadow=1;" vertex="1" parent="lane-jwt">
          <mxGeometry x="220" y="45" width="140" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="jwt-signature" value="Signature:&#xa;HMACSHA256(&#xa;  base64(header) + '.' +&#xa;  base64(payload),&#xa;  SECRET&#xa;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#66bb6a;strokeColor=#2e7d32;fontSize=6.5;fontColor=#ffffff;align=left;shadow=1;" vertex="1" parent="lane-jwt">
          <mxGeometry x="400" y="50" width="130" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="jwt-full" value="Full Token:&#xa;eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.&#xa;eyJ1c2VySWQiOiJjbGZ4Li4uIiwiZW1haWwiOiJ1c2VyQGV4YW1wbGUuY29tIiwicm9sZSI6ImFkbWluIiwiaWF0IjoxNzAyMzc3NjAwLCJleHAiOjE3MDI5ODI0MDB9.&#xa;SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3f51b5;fontSize=5;align=left;shadow=1;" vertex="1" parent="lane-jwt">
          <mxGeometry x="570" y="50" width="400" height="70" as="geometry" />
        </mxCell>
        
        <!-- Legend -->
        <mxCell id="legend-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="80" y="1440" width="480" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-title" value="LEGEND" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="1445" width="180" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-text" value="bcrypt: Industry-standard password hashing (10 salt rounds, ~100ms) | JWT: JSON Web Tokens for stateless authentication | authMiddleware: Applied to all protected routes | RBAC: 4 roles (user, admin, viewer, executor) | Token Expiry: 7 days (configurable) | Security: Passwords never stored in plain text, tokens verified on every request&#xa;Colors: Green=Register/Success | Blue=Login/Protected | Orange=Middleware | Purple=JWT/RBAC | Red=Hash/Error" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=6;" vertex="1" parent="1">
          <mxGeometry x="100" y="1470" width="440" height="35" as="geometry" />
        </mxCell>
        
        <!-- Metadata -->
        <mxCell id="metadata-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="1300" y="1440" width="400" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="metadata-title" value="METADATA" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1400" y="1445" width="200" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="metadata-text" value="Endpoints: POST /api/auth/register, POST /api/auth/login, GET /api/auth/me | Services: authService.js, authMiddleware.js, requireRole.js | Tables: User (id, username, email, password, role) | Libraries: bcrypt (v5+), jsonwebtoken (v9+) | Security: OWASP Top 10 compliant | Last Updated: 2025-12-12 | Complexity: Medium (40+ nodes, 4 flows)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=6;" vertex="1" parent="1">
          <mxGeometry x="1320" y="1470" width="360" height="35" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

