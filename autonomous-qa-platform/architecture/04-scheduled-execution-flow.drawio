<mxfile host="app.diagrams.net" modified="2025-12-12T15:00:00.000Z" agent="Autonomous QA - Scheduled Execution Flow" version="22.1.0">
  <diagram name="Scheduled Execution Flow (CronJobManager)" id="scheduled-flow">
    <mxGraphModel dx="2600" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="2600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Title -->
        <mxCell id="title-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a237e;strokeColor=#0d47a1;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="2520" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="title" value="Autonomous QA - Scheduled Execution Flow (Event-Driven CronJobManager + Advisory Locks)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="600" y="25" width="1400" height="35" as="geometry" />
        </mxCell>
        
        <mxCell id="subtitle" value="End-to-End: Server Startup → Load Schedules → Create Cron Jobs → Time Trigger → Advisory Locks → Bulk Execution → Update Next Run → Dynamic Updates" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="400" y="60" width="1800" height="20" as="geometry" />
        </mxCell>
        
        <!-- Phase 1: Server Startup & Initialization -->
        <mxCell id="phase1-title" value="═══ PHASE 1: Server Startup &amp; Initialization ═══" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#1976d2;" vertex="1" parent="1">
          <mxGeometry x="800" y="110" width="1000" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="lane-startup" value="Layer 1: Server Startup" style="swimlane;startSize=40;fillColor=#e1f5fe;strokeColor=#01579b;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="2520" height="240" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-server" value="backend/server.js&#xa;starts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=12;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="80" y="60" width="130" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-init-cron" value="1. Initialize&#xa;CronJobManager:&#xa;app.locals&#xa;.cronJobManager =&#xa;new CronJobManager()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="250" y="55" width="140" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-load-schedules" value="2. Load all schedules:&#xa;SELECT * FROM&#xa;scheduled_executions&#xa;WHERE enabled = true" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="430" y="55" width="150" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-for-each" value="FOR EACH&#xa;schedule" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=11;fontStyle=1;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="630" y="65" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-decode" value="3. Decode HTML Entities:&#xa;cronSchedule:&#xa;  '*&#x2F;5' → '*/5'&#xa;timezone:&#xa;  '&#x26;' → '&'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=8;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="790" y="60" width="150" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-create-job" value="4. Create node-cron Job:&#xa;const job =&#xa;  cron.schedule(&#xa;    cronSchedule,&#xa;    executeCallback,&#xa;    {&#xa;      timezone,&#xa;      scheduled: true&#xa;    }&#xa;  )" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff59d;strokeColor=#f57f17;fontSize=7;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="980" y="50" width="160" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-store-memory" value="5. Store in Memory:&#xa;jobsMap.set(&#xa;  scheduleId,&#xa;  {job, schedule}&#xa;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f4c3;strokeColor=#9e9d24;fontSize=9;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="1180" y="65" width="140" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-check-missed" value="6. Missed Job?&#xa;nextRunAt&#xa;&lt; NOW()" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="1370" y="65" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-execute-missed" value="Execute Now&#xa;(recover missed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ff5722;strokeColor=#bf360c;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="1540" y="70" width="110" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-ready" value="7. CronJobManager Ready&#xa;All schedules loaded&#xa;Total: N active jobs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=9;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="1850" y="60" width="160" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="startup-log" value="8. Log to console:&#xa;✓ CronJobManager:&#xa;  Loaded 5 schedules" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;strokeColor=#616161;fontSize=8;shadow=1;" vertex="1" parent="lane-startup">
          <mxGeometry x="2060" y="70" width="140" height="60" as="geometry" />
        </mxCell>
        
        <!-- Phase 2: Runtime Execution -->
        <mxCell id="phase2-title" value="═══ PHASE 2: Runtime Execution (When Cron Time is Reached) ═══" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#1976d2;" vertex="1" parent="1">
          <mxGeometry x="700" y="420" width="1200" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="lane-trigger" value="Layer 2: Cron Trigger" style="swimlane;startSize=40;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="2520" height="200" as="geometry" />
        </mxCell>
        
        <mxCell id="trigger-time" value="Time reached:&#xa;'0 2 * * *'&#xa;(Daily at 2:00 AM)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=11;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-trigger">
          <mxGeometry x="90" y="60" width="140" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="trigger-callback" value="node-cron triggers:&#xa;executeCallback()&#xa;(registered function)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=10;shadow=1;" vertex="1" parent="lane-trigger">
          <mxGeometry x="270" y="70" width="150" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="trigger-get-schedule" value="1. Get schedule details:&#xa;const schedule =&#xa;  jobsMap.get(scheduleId)&#xa;tag, mode, browser,&#xa;executionOrder" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff59d;strokeColor=#f57f17;fontSize=8;shadow=1;" vertex="1" parent="lane-trigger">
          <mxGeometry x="460" y="65" width="160" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="trigger-log-start" value="2. Log execution start:&#xa;⏰ Schedule '{name}'&#xa;triggered at {time}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;strokeColor=#616161;fontSize=8;shadow=1;" vertex="1" parent="lane-trigger">
          <mxGeometry x="660" y="75" width="140" height="60" as="geometry" />
        </mxCell>
        
        <!-- Advisory Lock Layer -->
        <mxCell id="lane-lock" value="Layer 3: PostgreSQL Advisory Lock (Multi-Server Safety)" style="swimlane;startSize=40;fillColor=#f3e5f5;strokeColor=#4a148c;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="2520" height="260" as="geometry" />
        </mxCell>
        
        <mxCell id="lock-hash" value="1. Calculate Lock ID:&#xa;lockId = hash(scheduleId)&#xa;using fnv1a algorithm&#xa;(deterministic hash)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#4a148c;fontSize=8;shadow=1;" vertex="1" parent="lane-lock">
          <mxGeometry x="660" y="60" width="160" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="lock-try" value="2. Try Acquire Lock:&#xa;SELECT&#xa;  pg_try_advisory_lock(&#xa;    lockId&#xa;  )" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;shadow=1;" vertex="1" parent="lane-lock">
          <mxGeometry x="860" y="55" width="150" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="lock-check" value="Lock&#xa;acquired?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=11;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-lock">
          <mxGeometry x="1060" y="65" width="110" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="lock-fail" value="Lock NOT acquired:&#xa;Another server&#xa;already executing&#xa;→ Skip this run&#xa;→ Log &amp; return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-lock">
          <mxGeometry x="1060" y="160" width="130" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="lock-success" value="Lock ACQUIRED:&#xa;This server will&#xa;execute the schedule&#xa;→ Proceed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=9;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-lock">
          <mxGeometry x="1230" y="70" width="130" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="lock-note" value="WHY Advisory Locks?&#xa;• Multi-server deployment safety&#xa;• Prevents duplicate execution&#xa;• No Redis required&#xa;• Automatic release on disconnect&#xa;• Lightweight (in-memory in PostgreSQL)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3f51b5;fontSize=7;align=left;shadow=1;" vertex="1" parent="lane-lock">
          <mxGeometry x="1420" y="60" width="200" height="100" as="geometry" />
        </mxCell>
        
        <!-- Execution Layer -->
        <mxCell id="lane-execution" value="Layer 4: Bulk Test Execution (Using atomicBulkExecutionService)" style="swimlane;startSize=40;fillColor=#e0f2f1;strokeColor=#004d40;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="970" width="2520" height="320" as="geometry" />
        </mxCell>
        
        <mxCell id="exec-query-flows" value="1. Query Flows by Tag:&#xa;SELECT * FROM test_flows&#xa;WHERE tags @&gt; ARRAY[tag]&#xa;AND status = 'active'&#xa;&#xa;Example:&#xa;tag = '@regression'&#xa;Found: 25 flows" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-execution">
          <mxGeometry x="1230" y="60" width="160" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="exec-check-flows" value="Flows&#xa;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=11;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-execution">
          <mxGeometry x="1255" y="200" width="110" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="exec-no-flows" value="No flows found:&#xa;• Log warning&#xa;• Update schedule:&#xa;  lastRunStatus = 'skipped'&#xa;• Release lock&#xa;• Return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-execution">
          <mxGeometry x="1100" y="205" width="130" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="exec-call-bulk" value="2. Call Bulk Service:&#xa;atomicBulkExecution&#xa;Service.execute({&#xa;  flows,&#xa;  tag,&#xa;  mode (parallel/sequential),&#xa;  browser,&#xa;  executionOrder,&#xa;  triggeredBy: 'System',&#xa;  triggerType: 'scheduled'&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=7;shadow=1;" vertex="1" parent="lane-execution">
          <mxGeometry x="1440" y="60" width="180" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="exec-bulk-process" value="3. Bulk Execution Process:&#xa;&#xa;See 03-bulk-execution-flow.drawio&#xa;for complete details:&#xa;&#xa;• Create parent TestRun&#xa;• Execute all N flows&#xa;  (parallel or sequential)&#xa;• Aggregate statistics&#xa;• Generate reports&#xa;• Send webhooks" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4dd0e1;strokeColor=#006064;fontSize=8;align=left;shadow=1;" vertex="1" parent="lane-execution">
          <mxGeometry x="1660" y="60" width="180" height="150" as="geometry" />
        </mxCell>
        
        <mxCell id="exec-result" value="4. Execution Complete:&#xa;bulkRunId,&#xa;status: 'passed'/'failed',&#xa;totalTests, passed, failed,&#xa;duration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-execution">
          <mxGeometry x="1880" y="80" width="150" height="90" as="geometry" />
        </mxCell>
        
        <!-- Post-Execution Layer -->
        <mxCell id="lane-post" value="Layer 5: Post-Execution Updates" style="swimlane;startSize=40;fillColor=#fff3e0;strokeColor=#e65100;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1310" width="2520" height="260" as="geometry" />
        </mxCell>
        
        <mxCell id="post-update-schedule" value="1. UPDATE Schedule:&#xa;UPDATE scheduled_executions&#xa;SET&#xa;  lastRunAt = NOW(),&#xa;  lastRunStatus = 'completed',&#xa;  lastRunId = bulkRunId,&#xa;  nextRunAt = calculateNext()&#xa;WHERE id = scheduleId" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-post">
          <mxGeometry x="1890" y="60" width="180" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="post-calc-next" value="2. Calculate nextRunAt:&#xa;if (isRecurring) {&#xa;  nextRunAt =&#xa;    cronParser.parseExpression(&#xa;      cronSchedule,&#xa;      {tz: timezone}&#xa;    ).next()&#xa;} else {&#xa;  nextRunAt = null&#xa;  enabled = false&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=6.5;shadow=1;" vertex="1" parent="lane-post">
          <mxGeometry x="2110" y="60" width="160" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="post-release-lock" value="3. Release Advisory Lock:&#xa;SELECT&#xa;  pg_advisory_unlock(&#xa;    lockId&#xa;  )&#xa;&#xa;IMPORTANT:&#xa;Always release lock&#xa;even if execution fails!" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-post">
          <mxGeometry x="2310" y="55" width="150" height="130" as="geometry" />
        </mxCell>
        
        <!-- Phase 3: Dynamic Updates -->
        <mxCell id="phase3-title" value="═══ PHASE 3: Dynamic Updates (No Server Restart Required!) ═══" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#1976d2;" vertex="1" parent="1">
          <mxGeometry x="700" y="1590" width="1200" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="lane-dynamic" value="Layer 6: Dynamic Schedule Management (Real-time Sync)" style="swimlane;startSize=40;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1640" width="2520" height="340" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-user-action" value="User Action in UI:&#xa;• Create schedule&#xa;• Update schedule&#xa;• Delete schedule&#xa;• Toggle enabled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="80" y="70" width="140" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-api-call" value="API Call:&#xa;POST /api/schedules&#xa;PUT /api/schedules/:id&#xa;DELETE /api/schedules/:id&#xa;POST /api/schedules/:id/toggle" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="260" y="70" width="160" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-save-db" value="1. Save to Database:&#xa;scheduleService.js&#xa;INSERT/UPDATE/DELETE&#xa;in scheduled_executions&#xa;table" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="460" y="70" width="150" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-route-hook" value="2. Route Hook Triggers:&#xa;(After DB save)&#xa;&#xa;req.app.locals&#xa;  .cronJobManager&#xa;  .syncJob(&#xa;    scheduleId,&#xa;    action&#xa;  )" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=7;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="650" y="65" width="150" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-action-check" value="Action&#xa;type?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=11;fontStyle=1;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="860" y="80" width="110" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-create" value="CREATE:&#xa;• Decode HTML&#xa;• Create cron job&#xa;• Add to jobsMap" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#81c784;strokeColor=#2e7d32;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="1020" y="60" width="120" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-update" value="UPDATE:&#xa;• Stop old job&#xa;• Remove from Map&#xa;• Create new job&#xa;• Add to Map" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#a5d6a7;strokeColor=#2e7d32;fontSize=7;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="1180" y="55" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-delete" value="DELETE:&#xa;• Stop job&#xa;• Remove from Map&#xa;• Cleanup" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffccbc;strokeColor=#d84315;fontSize=8;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="1340" y="60" width="120" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-toggle" value="TOGGLE:&#xa;• job.start()&#xa;  or&#xa;• job.stop()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=9;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="1500" y="65" width="100" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-no-restart" value="✓ Changes Applied!&#xa;&#xa;No server restart needed!&#xa;Cron jobs updated&#xa;in real-time" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="1660" y="70" width="160" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="dyn-pattern" value="INDUSTRY PATTERN:&#xa;&#xa;This follows:&#xa;• AWS CloudWatch Events&#xa;• GitHub Actions&#xa;• Jenkins Pipeline&#xa;• CircleCI Workflows&#xa;&#xa;Event-driven, no polling!" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=7;align=left;shadow=1;" vertex="1" parent="lane-dynamic">
          <mxGeometry x="1880" y="60" width="160" height="110" as="geometry" />
        </mxCell>
        
        <!-- Error Handling -->
        <mxCell id="lane-error" value="Layer 7: Error Handling &amp; Monitoring" style="swimlane;startSize=40;fillColor=#ffebee;strokeColor=#c62828;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="2000" width="2520" height="220" as="geometry" />
        </mxCell>
        
        <mxCell id="error-execution-fail" value="Execution Failed:&#xa;• Log error details&#xa;• Update lastRunStatus&#xa;• Release lock&#xa;• Notify if configured" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-error">
          <mxGeometry x="2320" y="70" width="140" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="error-lock-timeout" value="Lock Wait Timeout:&#xa;Another server took&#xa;too long&#xa;→ Skip this run" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffab91;strokeColor=#d84315;fontSize=9;shadow=1;" vertex="1" parent="lane-error">
          <mxGeometry x="2140" y="75" width="130" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="error-cron-invalid" value="Invalid Cron Expression:&#xa;• Log error&#xa;• Disable schedule&#xa;• Notify admin" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-error">
