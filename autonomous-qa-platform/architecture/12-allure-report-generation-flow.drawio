<mxfile host="app.diagrams.net" modified="2025-12-12T20:00:00.000Z" agent="Autonomous QA - Allure Reports" version="22.1.0">
  <diagram name="Allure Report Generation & Serving" id="allure-flow">
    <mxGraphModel dx="1800" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <mxCell id="title-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a237e;strokeColor=#0d47a1;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="title" value="Autonomous QA - Allure Report Generation &amp; Serving Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="400" y="30" width="1000" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="subtitle" value="Playwright JSON → Allure HTML | Enrichment with Metadata | Static Serving | Cleanup" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="500" y="60" width="800" height="20" as="geometry" />
        </mxCell>
        
        <!-- Test Execution Context -->
        <mxCell id="lane-context" value="Layer 1: Test Execution (Allure Reporter Active)" style="swimlane;startSize=30;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="1720" height="160" as="geometry" />
        </mxCell>
        
        <mxCell id="context-pw-config" value="playwright.config.js&#xa;reporter: [&#xa;  'allure-playwright'&#xa;]&#xa;&#xa;Output dir:&#xa;allure-results-{runId}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=7;shadow=1;" vertex="1" parent="lane-context">
          <mxGeometry x="80" y="50" width="130" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="context-during-test" value="During Test Execution:&#xa;Allure reporter writes:&#xa;• test-result.json&#xa;• attachment-*.png&#xa;• container.json&#xa;• executor.json" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#a5d6a7;strokeColor=#2e7d32;fontSize=7;shadow=1;" vertex="1" parent="lane-context">
          <mxGeometry x="250" y="55" width="140" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="context-after-test" value="After Test Completes:&#xa;All JSON files ready in:&#xa;allure-results-{runId}/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#66bb6a;strokeColor=#2e7d32;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-context">
          <mxGeometry x="430" y="65" width="130" height="55" as="geometry" />
        </mxCell>
        
        <!-- Report Generation -->
        <mxCell id="lane-generation" value="Layer 2: Report Generation (Allure CLI)" style="swimlane;startSize=30;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="1720" height="260" as="geometry" />
        </mxCell>
        
        <mxCell id="gen-trigger" value="allureReportService.js&#xa;generateReport(runId)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=9;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-generation">
          <mxGeometry x="440" y="50" width="120" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="gen-check-dir" value="1. Check Results Dir:&#xa;fs.existsSync(&#xa;  `allure-results-${runId}`&#xa;)&#xa;&#xa;If missing: throw error" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#90caf9;strokeColor=#1565c0;fontSize=7;shadow=1;" vertex="1" parent="lane-generation">
          <mxGeometry x="600" y="50" width="130" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="gen-spawn-allure" value="2. Spawn Allure CLI:&#xa;child_process.spawn(&#xa;  'allure',&#xa;  ['generate',&#xa;   'allure-results-{runId}',&#xa;   '-o',&#xa;   'allure-reports/{runId}',&#xa;   '--clean'&#xa;  ]&#xa;)&#xa;&#xa;Timeout: 60s" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1565c0;fontSize=6;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-generation">
          <mxGeometry x="770" y="45" width="150" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="gen-wait" value="3. Wait for Process:&#xa;Listen to stdout/stderr&#xa;&#xa;Exit code 0? → Success&#xa;Exit code != 0? → Error" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#42a5f5;strokeColor=#1565c0;fontSize=7;shadow=1;" vertex="1" parent="lane-generation">
          <mxGeometry x="960" y="55" width="130" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="gen-check-html" value="4. Verify HTML Exists:&#xa;fs.existsSync(&#xa;  `allure-reports/&#xa;   ${runId}/index.html`&#xa;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1e88e5;strokeColor=#1565c0;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-generation">
          <mxGeometry x="1130" y="60" width="130" height="65" as="geometry" />
        </mxCell>
        
        <mxCell id="gen-success" value="✓ Report Generated&#xa;Path:&#xa;allure-reports/{runId}/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=8;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-generation">
          <mxGeometry x="1300" y="65" width="120" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="gen-error" value="❌ Generation Failed:&#xa;Log stderr&#xa;Cleanup partial files&#xa;Throw error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-generation">
          <mxGeometry x="960" y="145" width="110" height="65" as="geometry" />
        </mxCell>
        
        <!-- Enrichment -->
        <mxCell id="lane-enrich" value="Layer 3: Report Enrichment (Add Metadata)" style="swimlane;startSize=30;fillColor=#f3e5f5;strokeColor=#4a148c;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="570" width="1720" height="200" as="geometry" />
        </mxCell>
        
        <mxCell id="enrich-read-env" value="1. Read environment.json:&#xa;fs.readFileSync(&#xa;  `allure-reports/{runId}/&#xa;   data/environment.json`&#xa;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#4a148c;fontSize=7;shadow=1;" vertex="1" parent="lane-enrich">
          <mxGeometry x="1310" y="50" width="140" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="enrich-add-meta" value="2. Add Custom Metadata:&#xa;env.push({&#xa;  Browser: 'chromium',&#xa;  Environment: 'staging',&#xa;  ExecutedBy: userName,&#xa;  FlowName: flowName,&#xa;  Tags: tags.join(', ')&#xa;})&#xa;&#xa;Write back to environment.json" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#7b1fa2;fontSize=6.5;shadow=1;" vertex="1" parent="lane-enrich">
          <mxGeometry x="1490" y="45" width="160" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="enrich-optional" value="Optional Enrichment:&#xa;• Inject custom CSS&#xa;• Add company logo&#xa;• Modify index.html" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ba68c8;strokeColor=#7b1fa2;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-enrich">
          <mxGeometry x="1670" y="60" width="120" height="70" as="geometry" />
        </mxCell>
        
        <!-- Storage & URL Update -->
        <mxCell id="lane-storage" value="Layer 4: Storage &amp; URL Update" style="swimlane;startSize=30;fillColor=#fff3e0;strokeColor=#e65100;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="790" width="1720" height="200" as="geometry" />
        </mxCell>
        
        <mxCell id="storage-url" value="1. Generate Report URL:&#xa;reportUrl =&#xa;  `http://localhost:3001/&#xa;   allure-reports/${runId}/`&#xa;&#xa;Or production:&#xa;  `https://qa.example.com/&#xa;   reports/${runId}/`" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=6.5;shadow=1;" vertex="1" parent="lane-storage">
          <mxGeometry x="80" y="50" width="160" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="storage-update-db" value="2. UPDATE TestRun:&#xa;UPDATE test_runs&#xa;SET&#xa;  reportUrl = url,&#xa;  reportGeneratedAt = NOW()&#xa;WHERE id = runId" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-storage">
          <mxGeometry x="280" y="55" width="140" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="storage-emit-ws" value="3. WebSocket Event:&#xa;socket.emit(&#xa;  'report:generated',&#xa;  {runId, reportUrl}&#xa;)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-storage">
          <mxGeometry x="460" y="65" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="storage-return" value="4. Return Response:&#xa;{&#xa;  success: true,&#xa;  reportUrl,&#xa;  generatedAt&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-storage">
          <mxGeometry x="620" y="70" width="110" height="65" as="geometry" />
        </mxCell>
        
        <!-- Serving -->
        <mxCell id="lane-serving" value="Layer 5: Static Serving (Express Static Middleware)" style="swimlane;startSize=30;fillColor=#e0f2f1;strokeColor=#004d40;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1010" width="1720" height="180" as="geometry" />
        </mxCell>
        
        <mxCell id="serve-middleware" value="server.js&#xa;app.use(&#xa;  '/allure-reports',&#xa;  express.static(&#xa;    'allure-reports'&#xa;  )&#xa;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=7;shadow=1;" vertex="1" parent="lane-serving">
          <mxGeometry x="80" y="50" width="130" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="serve-request" value="User clicks 'View Report':&#xa;Browser navigates to:&#xa;http://localhost:3001/&#xa;allure-reports/{runId}/" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4dd0e1;strokeColor=#006064;fontSize=7;shadow=1;" vertex="1" parent="lane-serving">
          <mxGeometry x="250" y="55" width="140" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="serve-express" value="Express serves:&#xa;• index.html&#xa;• app.js&#xa;• styles.css&#xa;• data/*.json&#xa;• history/*.json" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#26c6da;strokeColor=#006064;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-serving">
          <mxGeometry x="430" y="55" width="120" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="serve-browser" value="Browser Renders:&#xa;Allure HTML report&#xa;with interactive charts,&#xa;test history, trends" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00bcd4;strokeColor=#006064;fontSize=7;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-serving">
          <mxGeometry x="590" y="60" width="120" height="65" as="geometry" />
        </mxCell>
        
        <!-- Cleanup -->
        <mxCell id="lane-cleanup" value="Layer 6: Cleanup (Old Reports Deletion)" style="swimlane;startSize=30;fillColor=#ffebee;strokeColor=#c62828;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1210" width="1720" height="140" as="geometry" />
        </mxCell>
        
        <mxCell id="cleanup-cron" value="Scheduled Cron:&#xa;Daily at 4:00 AM&#xa;cleanupService.js" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-cleanup">
          <mxGeometry x="80" y="50" width="110" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="cleanup-query" value="Query Old Reports:&#xa;SELECT * FROM test_runs&#xa;WHERE reportGeneratedAt &lt;&#xa;  NOW() - 30 days" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-cleanup">
          <mxGeometry x="230" y="50" width="130" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="cleanup-delete-dirs" value="Delete Directories:&#xa;FOR EACH old report:&#xa;  fs.rmSync(&#xa;    `allure-reports/${runId}`,&#xa;    {recursive: true}&#xa;  )&#xa;  fs.rmSync(&#xa;    `allure-results-${runId}`,&#xa;    {recursive: true}&#xa;  )" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=6.5;shadow=1;" vertex="1" parent="lane-cleanup">
          <mxGeometry x="400" y="50" width="150" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="cleanup-update-db" value="UPDATE DB:&#xa;UPDATE test_runs&#xa;SET reportUrl = NULL,&#xa;    reportDeleted = true&#xa;WHERE id = runId" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-cleanup">
          <mxGeometry x="590" y="55" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="cleanup-log" value="Log Summary:&#xa;Deleted N reports&#xa;Freed X GB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-cleanup">
          <mxGeometry x="750" y="65" width="100" height="50" as="geometry" />
        </mxCell>
        
        <!-- Legend -->
        <mxCell id="legend-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="80" y="1400" width="460" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-title" value="LEGEND" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="1405" width="180" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-text" value="Allure CLI: Converts JSON results to interactive HTML | Enrichment: Adds custom metadata, logos, styling | Static Serving: Express middleware serves HTML | Cleanup: Scheduled deletion of old reports (retention policy) | WebSocket: Notifies frontend when report ready&#xa;Colors: Green=Execution | Blue=Generation | Purple=Enrichment | Orange=Storage/Cleanup | Cyan=Serving | Red Cylinders=DB" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=6;" vertex="1" parent="1">
          <mxGeometry x="100" y="1430" width="420" height="25" as="geometry" />
        </mxCell>
        
        <!-- Metadata -->
        <mxCell id="metadata-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="1300" y="1400" width="400" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="metadata-title" value="METADATA" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1400" y="1405" width="200" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="metadata-text" value="Services: allureReportService.js, cleanupService.js | Tables: TestRun | Dependencies: allure-playwright (reporter), allure CLI (generation) | Storage: allure-reports/ directory | Retention: 30 days (configurable) | Pattern: Allure Framework (open source by Qameta) | Last Updated: 2025-12-12 | Complexity: Medium (30+ nodes, 6 lanes)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=6;" vertex="1" parent="1">
          <mxGeometry x="1320" y="1430" width="360" height="25" as="geometry" />
        </mxCell>
        
      </root>
