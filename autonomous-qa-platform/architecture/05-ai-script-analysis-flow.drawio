        <mxCell id="ai-openai" value="OpenAIProvider" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#4a148c;fontSize=9;shadow=1;" vertex="1" parent="lane-ai-service">
          <mxGeometry x="750" y="145" width="100" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-claude" value="ClaudeProvider" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#4a148c;fontSize=9;shadow=1;" vertex="1" parent="lane-ai-service">
          <mxGeometry x="750" y="195" width="100" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-gemini" value="GeminiProvider" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#4a148c;fontSize=9;shadow=1;" vertex="1" parent="lane-ai-service">
          <mxGeometry x="750" y="245" width="100" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-others" value="+ 6 more providers:&#xa;Groq, Ollama, Mistral,&#xa;Cohere, LocalAI, Custom" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#7b1fa2;fontSize=7;shadow=1;" vertex="1" parent="lane-ai-service">
          <mxGeometry x="620" y="175" width="110" height="60" as="geometry" />
        </mxCell>
        
        <!-- Knowledge Base & Context Layer -->
        <mxCell id="lane-context" value="Layer 4: Context Building (Knowledge Base + Test Script)" style="swimlane;startSize=40;fillColor=#e0f2f1;strokeColor=#004d40;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="890" width="2120" height="240" as="geometry" />
        </mxCell>
        
        <mxCell id="kb-load" value="1. Load Knowledge Base:&#xa;fs.readdir(&#xa;  'data/knowledge-base/'&#xa;)&#xa;Read all .md files" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=8;shadow=1;" vertex="1" parent="lane-context">
          <mxGeometry x="620" y="60" width="140" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="kb-parse" value="2. Parse Markdown:&#xa;Extract sections:&#xa;• Best practices&#xa;• Coding standards&#xa;• Common patterns&#xa;• Error handling" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=7;shadow=1;" vertex="1" parent="lane-context">
          <mxGeometry x="800" y="55" width="140" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="ctx-build" value="3. Build Context:&#xa;messages = [&#xa;  {role: 'system',&#xa;   content: systemPrompt +&#xa;     knowledgeBase},&#xa;  {role: 'user',&#xa;   content: '# Test Script\\n' +&#xa;     rawScript + '\\n\\n' +&#xa;     '# User Query\\n' +&#xa;     prompt}&#xa;]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4dd0e1;strokeColor=#006064;fontSize=6.5;shadow=1;" vertex="1" parent="lane-context">
          <mxGeometry x="980" y="50" width="180" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="ctx-system-prompt" value="System Prompt by Intent:&#xa;&#xa;QUESTION:&#xa;'Analyze and explain this test&#xa;script. Be concise.'&#xa;&#xa;MODIFICATION:&#xa;'Generate modified script&#xa;with requested changes.&#xa;Return complete code.'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=7;align=left;shadow=1;" vertex="1" parent="lane-context">
          <mxGeometry x="1200" y="55" width="180" height="100" as="geometry" />
        </mxCell>
        
        <!-- API Call & Retry Layer -->
        <mxCell id="lane-api-call" value="Layer 5: AI API Call (Retry with Exponential Backoff)" style="swimlane;startSize=40;fillColor=#fff3e0;strokeColor=#e65100;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1150" width="2120" height="340" as="geometry" />
        </mxCell>
        
        <mxCell id="call-api" value="Call AI Provider API:&#xa;POST provider.endpoint&#xa;Headers: {&#xa;  Authorization: apiKey,&#xa;  Content-Type: 'json'&#xa;}&#xa;Body: {&#xa;  model, messages,&#xa;  temperature, maxTokens&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=7;shadow=1;" vertex="1" parent="lane-api-call">
          <mxGeometry x="1210" y="60" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="call-timeout" value="Timeout: 30s&#xa;(configurable)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffccbc;strokeColor=#d84315;fontSize=9;shadow=1;" vertex="1" parent="lane-api-call">
          <mxGeometry x="1230" y="190" width="120" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="call-response-check" value="API&#xa;success?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api-call">
          <mxGeometry x="1250" y="250" width="80" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="call-success" value="SUCCESS:&#xa;Parse response&#xa;Extract content" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api-call">
          <mxGeometry x="1410" y="260" width="110" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="call-retry-check" value="Retry&#xa;count &lt; 3?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api-call">
          <mxGeometry x="1080" y="260" width="90" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="call-retry" value="RETRY:&#xa;Wait (exponential):&#xa;• Attempt 1: 1s&#xa;• Attempt 2: 2s&#xa;• Attempt 3: 4s" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api-call">
          <mxGeometry x="1050" y="150" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="call-fallback-check" value="Fallback&#xa;providers&#xa;available?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api-call">
          <mxGeometry x="900" y="265" width="90" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="call-try-fallback" value="TRY NEXT PROVIDER:&#xa;Get next active provider&#xa;(priority order)&#xa;Repeat API call" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffab91;strokeColor=#d84315;fontSize=8;shadow=1;" vertex="1" parent="lane-api-call">
          <mxGeometry x="740" y="265" width="130" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="call-all-failed" value="ALL PROVIDERS FAILED:&#xa;Return error to user&#xa;'AI analysis unavailable'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-api-call">
          <mxGeometry x="880" y="150" width="140" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="call-circuit-breaker" value="Circuit Breaker:&#xa;5 consecutive failures&#xa;→ Disable provider 5min" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#bcaaa4;strokeColor=#5d4037;fontSize=8;shadow=1;" vertex="1" parent="lane-api-call">
          <mxGeometry x="725" y="150" width="130" height="60" as="geometry" />
        </mxCell>
        
        <!-- Response Processing -->
        <mxCell id="lane-response" value="Layer 6: Response Processing &amp; Usage Tracking" style="swimlane;startSize=40;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1510" width="2120" height="260" as="geometry" />
        </mxCell>
        
        <mxCell id="resp-parse" value="1. Parse AI Response:&#xa;response.choices[0]&#xa;  .message.content&#xa;&#xa;Extract:&#xa;• Modified code (if any)&#xa;• Explanation&#xa;• Suggestions" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=8;shadow=1;" vertex="1" parent="lane-response">
          <mxGeometry x="1420" y="60" width="140" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="resp-validate" value="2. Validate Response:&#xa;• Check for code blocks&#xa;• Verify syntax&#xa;• Sanitize output" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#a5d6a7;strokeColor=#2e7d32;fontSize=9;shadow=1;" vertex="1" parent="lane-response">
          <mxGeometry x="1600" y="70" width="130" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="resp-track-usage" value="3. Track Usage:&#xa;usageTracker.increment({&#xa;  provider,&#xa;  model,&#xa;  promptTokens,&#xa;  completionTokens,&#xa;  totalTokens,&#xa;  requestTime,&#xa;  cost (estimated)&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#81c784;strokeColor=#2e7d32;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-response">
          <mxGeometry x="1770" y="60" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="resp-http" value="4. HTTP Response:&#xa;200 OK&#xa;{&#xa;  success: true,&#xa;  intent,&#xa;  response,&#xa;  provider,&#xa;  tokensUsed&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-response">
          <mxGeometry x="1960" y="70" width="120" height="90" as="geometry" />
        </mxCell>
        
