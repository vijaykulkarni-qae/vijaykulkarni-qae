        <mxCell id="subtitle" value="9 AI Providers | Intent Detection | Knowledge Base Integration | Circuit Breaker | Usage Tracking" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="600" y="60" width="1000" height="20" as="geometry" />
        </mxCell>
        
        <!-- User/Frontend Layer -->
        <mxCell id="lane-user" value="Layer 1: User / Frontend (AI Chat Interface)" style="swimlane;startSize=40;fillColor=#e1f5fe;strokeColor=#01579b;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="2120" height="180" as="geometry" />
        </mxCell>
        
        <mxCell id="user-open-chat" value="1. User opens&#xa;AI Chat for&#xa;test flow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=11;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="70" y="60" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="user-type-query" value="2. User types query:&#xa;&#xa;'Add error handling&#xa;to login steps'&#xa;or&#xa;'What does this test do?'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="230" y="55" width="170" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="user-send" value="3. Click Send&#xa;or press Enter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="440" y="65" width="110" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="user-loading" value="4. See Loading:&#xa;'AI is analyzing...'" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="1450" y="65" width="120" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="user-response" value="5. View Response:&#xa;• Question: Show answer&#xa;• Modification: Show&#xa;  Accept/Reject buttons" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="1920" y="60" width="140" height="70" as="geometry" />
        </mxCell>
        
        <!-- Backend API Layer -->
        <mxCell id="lane-api" value="Layer 2: Backend API + Intent Detection" style="swimlane;startSize=40;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="2120" height="220" as="geometry" />
        </mxCell>
        
        <mxCell id="api-post" value="POST /api/ai/analyze&#xa;Body: {&#xa;  flowId,&#xa;  prompt,&#xa;  intent: 'auto'&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="445" y="60" width="130" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="api-auth" value="1. Auth Check" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=10;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="610" y="70" width="90" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="api-load-flow" value="2. Load TestFlow:&#xa;SELECT * FROM test_flows&#xa;WHERE id = flowId&#xa;Get rawScript, steps" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="740" y="55" width="130" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="api-intent-detect" value="3. Intent Detection:&#xa;&#xa;Keywords:&#xa;'what/how/why/explain'&#xa;→ QUESTION&#xa;&#xa;'add/change/update/fix'&#xa;→ MODIFICATION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=7;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="910" y="50" width="150" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="api-call-service" value="4. Call globalAIService:&#xa;analyzeScript({&#xa;  flowId,&#xa;  rawScript,&#xa;  steps,&#xa;  prompt,&#xa;  intent&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="1100" y="60" width="140" height="80" as="geometry" />
        </mxCell>
        
        <!-- AI Service Layer -->
        <mxCell id="lane-ai-service" value="Layer 3: Global AI Service (Provider Selection &amp; Orchestration)" style="swimlane;startSize=40;fillColor=#f3e5f5;strokeColor=#4a148c;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="550" width="2120" height="320" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-service-start" value="globalAIService.js&#xa;analyzeScript()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=11;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-ai-service">
          <mxGeometry x="1110" y="60" width="120" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-load-primary" value="1. Load Primary Provider:&#xa;SELECT * FROM ai_providers&#xa;WHERE isPrimary = true&#xa;AND isActive = true" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-ai-service">
          <mxGeometry x="1110" y="140" width="140" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-check-provider" value="Provider&#xa;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-ai-service">
          <mxGeometry x="1140" y="250" width="80" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-no-provider" value="Error: No AI&#xa;provider configured" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-ai-service">
          <mxGeometry x="1000" y="255" width="100" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-provider-router" value="2. Route to Provider:&#xa;switch(provider.name)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ba68c8;strokeColor=#7b1fa2;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-ai-service">
          <mxGeometry x="920" y="130" width="140" height="80" as="geometry" />
