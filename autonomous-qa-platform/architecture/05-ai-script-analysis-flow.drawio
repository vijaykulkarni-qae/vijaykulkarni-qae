        <mxCell id="metadata-title" value="METADATA" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1770" y="1825" width="200" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="metadata-text" value="Services: globalAIService.js, 9 provider files, knowledgeBaseManager.js, usageTracker.js | Tables: AIProvider, TestFlow, TestFlowVersion (if modified) | Endpoint: POST /api/ai/analyze | Providers: OpenAI GPT-4, Claude 3, Gemini Pro, Groq, Ollama, Mistral, Cohere, LocalAI, Custom | Last Updated: 2025-12-12 | Complexity: Complex (60+ nodes, 6 lanes)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=6.5;" vertex="1" parent="1">
