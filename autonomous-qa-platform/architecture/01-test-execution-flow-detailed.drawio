        <mxCell id="timing-allure" value="~5-10s" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#666666;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="1820" y="1850" width="60" height="20" as="geometry" />
        </mxCell>
        
      </root>
