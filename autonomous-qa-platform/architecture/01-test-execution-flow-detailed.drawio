        <mxCell id="webhook-check" value="Webhooks&#xa;enabled?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=10;fontColor=#ffffff;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1260" y="180" width="120" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-send" value="8. webhookService.js&#xa;Send notifications:&#xa;- Query active webhooks&#xa;- Build payload from fields&#xa;- POST to webhook URLs&#xa;- Fire-and-forget&#xa;- Log success/failure" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#81c784;strokeColor=#2e7d32;fontSize=8;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1060" y="170" width="180" height="110" as="geometry" />
