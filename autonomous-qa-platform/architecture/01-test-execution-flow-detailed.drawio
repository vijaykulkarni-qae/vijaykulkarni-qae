        <mxCell id="allure-url" value="4. Get Report URL:&#xa;/allure-reports/{runId}/#" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ba68c8;strokeColor=#4a148c;fontSize=10;fontColor=#ffffff;" vertex="1" parent="lane-post-exec">
