        <mxCell id="timing-exec" value="1-5 min&#xa;(depends on test)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#666666;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="1600" y="1300" width="80" height="30" as="geometry" />
