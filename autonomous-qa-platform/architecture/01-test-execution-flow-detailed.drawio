        <mxCell id="legend-ws" value="WebSocket Event" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=11;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="80" y="2630" width="160" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-db" value="Database Operation" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="2625" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-decision" value="Decision Point" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=11;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="80" y="2690" width="160" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-service" value="Service / Process" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=11;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="280" y="2695" width="160" height="50" as="geometry" />
        </mxCell>
        
        <!-- Notes Box -->
        <mxCell id="notes-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffde7;strokeColor=#f57f17;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="2540" width="500" height="220" as="geometry" />
        </mxCell>
        
        <mxCell id="notes-title" value="KEY NOTES" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="500" y="2550" width="500" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="notes-text" value="1. WebSocket emits 'execution:started', 'step:completed', 'execution:completed' for real-time updates&#xa;2. All database operations use Prisma transactions (ACID compliance)&#xa;3. Playwright runs as child process (isolated execution)&#xa;4. Allure report generated post-execution (enriched with categories)&#xa;5. Webhooks are fire-and-forget (never block test execution)&#xa;6. Temp files cleaned up after execution&#xa;7. Full audit trail logged to AuditLog table&#xa;8. Upload files validated before execution starts&#xa;9. TestFlow stats updated: executionCount++, successRate recalculated&#xa;10. Assets saved: screenshots (PNG), videos (WEBM), traces (ZIP)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="520" y="2590" width="460" height="160" as="geometry" />
        </mxCell>
        
        <!-- Timing annotations -->
        <mxCell id="timing-auth" value="~50ms" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#666666;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="420" y="360" width="60" height="20" as="geometry" />
