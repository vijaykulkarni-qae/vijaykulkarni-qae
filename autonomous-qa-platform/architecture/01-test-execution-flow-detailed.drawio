        </mxCell>
        
        <mxCell id="calc-stats" value="5. Calculate Stats:&#xa;totalTests = count(steps)&#xa;passedTests = count(passed)&#xa;failedTests = count(failed)&#xa;skippedTests = count(skipped)&#xa;duration = endTime - startTime" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe082;strokeColor=#f57f17;fontSize=8;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1440" y="60" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="update-testrun" value="6. Update TestRun:&#xa;status: 'passed'/'failed'&#xa;endTime: NOW()&#xa;duration: ms&#xa;totalTests, passedTests,&#xa;failedTests, skippedTests&#xa;allureReportUrl" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1440" y="190" width="160" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="update-flow-stats" value="7. Update TestFlow:&#xa;lastExecutedAt: NOW()&#xa;executionCount++&#xa;successRate: %&#xa;(aggregate stats)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1440" y="330" width="160" height="90" as="geometry" />
