        <mxCell id="save-assets-db" value="2. Save to TestAsset:&#xa;INSERT INTO test_assets&#xa;(runId, type, filePath,&#xa;sizeBytes, width, height)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=9;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1620" y="170" width="160" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="allure-generate" value="3. Generate Allure Report&#xa;allureEnrichmentService.js:&#xa;- allure generate&#xa;- Enrich with categories&#xa;- Custom branding&#xa;- P0/P1/P2 grouping" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#4a148c;fontSize=9;" vertex="1" parent="lane-post-exec">
