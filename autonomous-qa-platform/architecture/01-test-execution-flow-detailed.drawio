        <mxCell id="write-temp-file" value="5. Write test script&#xa;to temp file&#xa;/tmp/test-{runId}.spec.js" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=9;" vertex="1" parent="lane-exec-service">
