        <mxCell id="collect-assets" value="1. Collect Assets:&#xa;- Screenshots (.png)&#xa;- Videos (.webm)&#xa;- Traces (.zip)&#xa;- Logs (.json)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8bbd0;strokeColor=#880e4f;fontSize=10;" vertex="1" parent="lane-post-exec">
