        <mxCell id="return-response" value="11. Return API Response:&#xa;200 OK&#xa;{runId, status, duration,&#xa;reportUrl, totalTests,&#xa;passedTests, failedTests}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=9;fontColor=#ffffff;fontStyle=1" vertex="1" parent="lane-post-exec">
