        <mxCell id="webhook-payload" value="Webhook Payload:&#xa;{testName, status,&#xa;totalTests, passedTests,&#xa;failedTests, duration,&#xa;reportUrl, triggeredBy,&#xa;completedAt}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=8;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1060" y="300" width="180" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-targets" value="Send to:&#xa;- Google Chat&#xa;- Slack&#xa;- Microsoft Teams&#xa;- Discord&#xa;- Custom endpoints" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#a5d6a7;strokeColor=#2e7d32;fontSize=8;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="860" y="190" width="180" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="emit-complete" value="9. WebSocket Emit&#xa;'execution:completed'&#xa;{runId, status, duration,&#xa;totalTests, passedTests,&#xa;failedTests, reportUrl}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1250" y="340" width="160" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="cleanup-temp" value="10. Cleanup:&#xa;- Delete temp test file&#xa;- Clear temp data&#xa;- Release resources" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=9;" vertex="1" parent="lane-post-exec">
