        <mxCell id="pw-browser-launch" value="1. Launch Browser&#xa;chromium.launch({&#xa;  headless: true,&#xa;  video: 'on',&#xa;  screenshot: 'on'&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=9;" vertex="1" parent="lane-playwright">
