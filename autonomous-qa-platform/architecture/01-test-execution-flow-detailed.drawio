        <mxCell id="create-testrun" value="2. Create TestRun&#xa;status: 'running'&#xa;triggeredBy: userId&#xa;startTime: NOW()" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=9;" vertex="1" parent="lane-exec-service">
