<mxfile host="app.diagrams.net" modified="2025-12-12T13:00:00.000Z" agent="Autonomous QA - Test Recording Flow" version="22.1.0">
  <diagram name="Test Recording & Creation Flow" id="recording-flow">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Title Section -->
        <mxCell id="title-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a237e;strokeColor=#0d47a1;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1920" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="title" value="Autonomous QA - Test Recording &amp; Creation Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="600" y="25" width="800" height="35" as="geometry" />
        </mxCell>
        
        <mxCell id="subtitle" value="End-to-End: User Action → Playwright Codegen → File Watcher → AST Parser → Atomic Save → Database" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="400" y="60" width="1200" height="20" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: User/Frontend Layer -->
        <mxCell id="lane-user" value="Layer 1: User / Frontend (React)" style="swimlane;startSize=40;fillColor=#e1f5fe;strokeColor=#01579b;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="1920" height="180" as="geometry" />
        </mxCell>
        
        <mxCell id="user-click-record" value="1. User clicks&#xa;'Record Test'&#xa;button" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=12;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="60" y="60" width="130" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="frontend-post-start" value="2. POST /api/record/start&#xa;Headers: Authorization&#xa;Body: {&#xa;  folderId,&#xa;  testName,&#xa;  baseUrl&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="230" y="55" width="170" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="frontend-wait" value="3. Show Recording UI:&#xa;• Status: 'Recording...'&#xa;• Timer: 00:00&#xa;• Stop button&#xa;• Instructions" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="1220" y="60" width="150" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="frontend-progress" value="4. Real-time updates:&#xa;File watcher events&#xa;'step:detected'&#xa;Show step count" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="1530" y="65" width="130" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="frontend-complete" value="5. User stops recording&#xa;or auto-complete&#xa;Navigate to&#xa;Flow Editor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="1710" y="60" width="150" height="80" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Backend API -->
        <mxCell id="lane-api" value="Layer 2: Backend API + Security (Express.js)" style="swimlane;startSize=40;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="1920" height="220" as="geometry" />
        </mxCell>
        
        <mxCell id="api-auth" value="1. authMiddleware.js&#xa;• Verify JWT&#xa;• Load user&#xa;• Check permissions" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=10;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="230" y="60" width="150" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="api-route" value="2. recordingRoutes.js&#xa;POST /api/record/start&#xa;• Validate inputs&#xa;• Check folder exists&#xa;• Check name unique" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="420" y="55" width="170" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="api-call-service" value="3. Call Service:&#xa;recordingService&#xa;.startRecording({&#xa;  userId,&#xa;  folderId,&#xa;  testName,&#xa;  baseUrl&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="640" y="60" width="160" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="api-response" value="4. HTTP Response:&#xa;200 OK&#xa;{&#xa;  recordingId,&#xa;  status: 'recording',&#xa;  processId&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="1090" y="65" width="150" height="80" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Recording Service -->
        <mxCell id="lane-recording-service" value="Layer 3: Recording Service (recordingService.js)" style="swimlane;startSize=40;fillColor=#f3e5f5;strokeColor=#4a148c;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="550" width="1920" height="280" as="geometry" />
        </mxCell>
        
        <mxCell id="rec-service-start" value="recordingService.js&#xa;startRecording()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=11;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-recording-service">
          <mxGeometry x="640" y="60" width="140" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="rec-create-dir" value="1. Ensure directory:&#xa;recordings/&#xa;Create if not exists" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=9;shadow=1;" vertex="1" parent="lane-recording-service">
          <mxGeometry x="820" y="65" width="140" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="rec-spawn-codegen" value="2. Spawn Playwright Codegen:&#xa;child_process.spawn(&#xa;'npx playwright codegen',&#xa;{&#xa;  args: [baseUrl,&#xa;         '--target=javascript',&#xa;         '--output=recordings/{testName}.spec.js'],&#xa;  detached: false&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#00bcd4;strokeColor=#006064;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-recording-service">
          <mxGeometry x="990" y="50" width="230" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="rec-store-process" value="3. Store Process Info:&#xa;in-memory Map&#xa;recordingId → {&#xa;  processId,&#xa;  userId,&#xa;  startTime,&#xa;  status: 'active'&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#4a148c;fontSize=8;shadow=1;" vertex="1" parent="lane-recording-service">
          <mxGeometry x="1260" y="60" width="160" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="rec-setup-watcher" value="4. Setup File Watcher:&#xa;Watch recordings/*.spec.js&#xa;fs.watch(&#xa;  'recordings/',&#xa;  {recursive: true}&#xa;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=8;shadow=1;" vertex="1" parent="lane-recording-service">
          <mxGeometry x="1460" y="65" width="170" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="rec-error-handler" value="Error Handler:&#xa;Process crash?&#xa;→ Cleanup&#xa;→ Notify user" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-recording-service">
          <mxGeometry x="1000" y="180" width="130" height="70" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Playwright Codegen -->
        <mxCell id="lane-codegen" value="Layer 4: Playwright Codegen (Child Process)" style="swimlane;startSize=40;fillColor=#e0f2f1;strokeColor=#004d40;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="850" width="1920" height="240" as="geometry" />
        </mxCell>
        
        <mxCell id="codegen-start" value="Playwright Codegen&#xa;Process Starts&#xa;PID: {processId}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00bcd4;strokeColor=#006064;fontSize=11;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-codegen">
          <mxGeometry x="1000" y="60" width="150" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="codegen-browser" value="1. Launch Browser:&#xa;Chromium (headed)&#xa;Open target URL:&#xa;{baseUrl}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=10;shadow=1;" vertex="1" parent="lane-codegen">
          <mxGeometry x="1190" y="60" width="140" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="codegen-record" value="2. User Performs Actions:&#xa;• Click elements&#xa;• Type text&#xa;• Navigate pages&#xa;• Wait for elements&#xa;• Assertions&#xa;&#xa;Codegen watches&#xa;and generates code" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4dd0e1;strokeColor=#006064;fontSize=8;shadow=1;" vertex="1" parent="lane-codegen">
          <mxGeometry x="1370" y="50" width="160" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="codegen-write" value="3. Write to File:&#xa;recordings/{testName}.spec.js&#xa;&#xa;Continuous write&#xa;as user performs actions" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=9;shadow=1;" vertex="1" parent="lane-codegen">
          <mxGeometry x="1570" y="60" width="180" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="codegen-stop" value="User closes browser&#xa;or clicks Stop&#xa;→ Process exits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-codegen">
          <mxGeometry x="1580" y="160" width="140" height="50" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: File Watcher & Parser -->
        <mxCell id="lane-watcher" value="Layer 5: File Watcher &amp; AST Parser" style="swimlane;startSize=40;fillColor=#fff3e0;strokeColor=#e65100;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1110" width="1920" height="320" as="geometry" />
        </mxCell>
        
        <mxCell id="watcher-detect" value="File Watcher Detects:&#xa;recordings/{testName}.spec.js&#xa;changed or created" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-watcher">
          <mxGeometry x="1580" y="60" width="150" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="watcher-debounce" value="Debounce (500ms):&#xa;Wait for file&#xa;writing to complete" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=9;shadow=1;" vertex="1" parent="lane-watcher">
          <mxGeometry x="1590" y="160" width="130" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="watcher-read-file" value="Read File:&#xa;fs.readFileSync(&#xa;  recordings/{testName}.spec.js,&#xa;  'utf-8'&#xa;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=8;shadow=1;" vertex="1" parent="lane-watcher">
          <mxGeometry x="1430" y="165" width="140" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="parser-start" value="astPlaywrightParser.js&#xa;parse(rawScript)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=11;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-watcher">
          <mxGeometry x="1250" y="170" width="150" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="parser-babel" value="1. Babel AST:&#xa;@babel/parser&#xa;Parse JS to AST&#xa;ast = parse(rawScript,&#xa;  {sourceType: 'module'})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#4a148c;fontSize=8;shadow=1;" vertex="1" parent="lane-watcher">
          <mxGeometry x="1060" y="160" width="160" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="parser-traverse" value="2. Traverse AST:&#xa;@babel/traverse&#xa;Extract test steps:&#xa;• page.goto()&#xa;• page.click()&#xa;• page.fill()&#xa;• expect()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#7b1fa2;fontSize=8;shadow=1;" vertex="1" parent="lane-watcher">
          <mxGeometry x="860" y="155" width="170" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="parser-steps" value="3. Build Steps Array:&#xa;[&#xa;  {stepId: 1, action: 'goto',&#xa;   selector: null,&#xa;   value: 'https://...'},&#xa;  {stepId: 2, action: 'click',&#xa;   selector: '#login-btn',&#xa;   value: null},&#xa;  ...&#xa;]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ab47bc;strokeColor=#6a1b9a;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-watcher">
          <mxGeometry x="650" y="150" width="180" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="parser-success" value="Parsing&#xa;successful?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=11;shadow=1;" vertex="1" parent="lane-watcher">
          <mxGeometry x="490" y="170" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="parser-error" value="Parse Error:&#xa;• Log error&#xa;• Notify user&#xa;• Keep recording active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-watcher">
          <mxGeometry x="340" y="175" width="120" height="80" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Atomic Save Service -->
        <mxCell id="lane-atomic" value="Layer 6: Atomic Save Service (atomicFlowSaveService.js)" style="swimlane;startSize=40;fillColor=#e8eaf6;strokeColor=#3f51b5;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1450" width="1920" height="340" as="geometry" />
        </mxCell>
        
        <mxCell id="atomic-start" value="atomicFlowSaveService.js&#xa;execute({&#xa;  name, description,&#xa;  rawScript, steps,&#xa;  folderId, createdBy&#xa;})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5c6bc0;strokeColor=#3f51b5;fontSize=9;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-atomic">
          <mxGeometry x="490" y="60" width="160" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="atomic-backup" value="1. Create Backup:&#xa;/tmp/flow-backup-{uuid}.json&#xa;{&#xa;  rawScript, steps,&#xa;  timestamp, userId&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=8;shadow=1;" vertex="1" parent="lane-atomic">
          <mxGeometry x="690" y="70" width="160" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="atomic-transaction" value="2. Prisma Transaction:&#xa;await prisma.$transaction([&#xa;  // Multiple operations&#xa;])" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#7986cb;strokeColor=#3f51b5;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-atomic">
          <mxGeometry x="890" y="75" width="170" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="atomic-create-flow" value="3. CREATE TestFlow:&#xa;INSERT INTO test_flows&#xa;{&#xa;  id: cuid(),&#xa;  name, description,&#xa;  rawScript, steps,&#xa;  folderId, createdBy,&#xa;  version: 1,&#xa;  status: 'active',&#xa;  recordedAt: NOW()&#xa;}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-atomic">
          <mxGeometry x="1100" y="55" width="160" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="atomic-create-version" value="4. CREATE TestFlowVersion:&#xa;INSERT INTO test_flow_versions&#xa;{&#xa;  flowId,&#xa;  version: 1,&#xa;  rawScript, steps,&#xa;  changedBy: createdBy,&#xa;  changeReason: 'Initial recording',&#xa;  createdAt: NOW()&#xa;}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-atomic">
          <mxGeometry x="1300" y="55" width="180" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="atomic-update-folder" value="5. UPDATE Folder:&#xa;UPDATE folders&#xa;SET updatedAt = NOW()&#xa;WHERE id = folderId" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;shadow=1;" vertex="1" parent="lane-atomic">
          <mxGeometry x="1520" y="70" width="140" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="atomic-check" value="Transaction&#xa;success?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=11;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-atomic">
          <mxGeometry x="1530" y="190" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="atomic-commit" value="COMMIT Transaction&#xa;Delete backup file&#xa;SUCCESS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-atomic">
          <mxGeometry x="1690" y="195" width="140" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="atomic-rollback" value="ROLLBACK Transaction&#xa;Restore from backup&#xa;Log error&#xa;Retry once" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-atomic">
          <mxGeometry x="1350" y="200" width="140" height="70" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Audit & Response -->
        <mxCell id="lane-audit" value="Layer 7: Audit Log &amp; Response" style="swimlane;startSize=40;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1810" width="1920" height="220" as="geometry" />
        </mxCell>
        
        <mxCell id="audit-log" value="1. INSERT audit_logs:&#xa;{&#xa;  userId,&#xa;  action: 'CREATE',&#xa;  resource: 'TestFlow',&#xa;  resourceId: flowId,&#xa;  details: {name, steps: N},&#xa;  ipAddress,&#xa;  userAgent,&#xa;  timestamp: NOW()&#xa;}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-audit">
          <mxGeometry x="1690" y="55" width="180" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="audit-cleanup-recording" value="2. Cleanup Recording:&#xa;• Stop file watcher&#xa;• Remove from&#xa;  in-memory Map&#xa;• Keep .spec.js file" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=9;shadow=1;" vertex="1" parent="lane-audit">
          <mxGeometry x="1470" y="70" width="150" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="audit-emit-complete" value="3. WebSocket Emit:&#xa;'recording:complete'&#xa;{&#xa;  flowId, flowName,&#xa;  totalSteps,&#xa;  duration&#xa;}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-audit">
          <mxGeometry x="1260" y="75" width="150" height="85" as="geometry" />
        </mxCell>
        
        <mxCell id="audit-http-response" value="4. HTTP Response:&#xa;200 OK&#xa;{&#xa;  success: true,&#xa;  flowId,&#xa;  flowName,&#xa;  totalSteps,&#xa;  version: 1&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-audit">
          <mxGeometry x="1050" y="75" width="160" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="audit-navigate" value="5. Frontend navigates:&#xa;/flows/{flowId}/edit&#xa;User can now&#xa;edit or run test" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-audit">
          <mxGeometry x="840" y="75" width="150" height="85" as="geometry" />
        </mxCell>
        
        <!-- Legend -->
        <mxCell id="legend-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="80" y="2080" width="480" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-title" value="LEGEND" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="2090" width="180" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-text" value="Colors: Green=User/Success | Blue=API | Purple=Services | Red Cylinders=DB | Orange Ellipses=WebSocket | Cyan=Playwright | Gray=Files&#xa;Shapes: Rectangle=Process | Diamond=Decision | Cylinder=Database | Ellipse=Event | Rounded=Start/End" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="2115" width="440" height="45" as="geometry" />
        </mxCell>
        
        <!-- Metadata -->
        <mxCell id="metadata-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;opacity=80;" vertex="1" parent="1">
