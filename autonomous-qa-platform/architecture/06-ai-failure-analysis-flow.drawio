          <mxGeometry x="230" y="1485" width="200" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-text" value="Automatic Analysis: Triggers after any test failure (non-blocking) | AI Providers: Uses same multi-provider system as script analysis | Deviation: Stored in database for historical tracking | Confidence Scoring: 0-100 (AI estimates accuracy)&#xa;Colors: Red=Failure/Trigger | Purple=AI Services | Cyan=External AI | Orange=Events | Red Cylinders=DB" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=7;" vertex="1" parent="1">
