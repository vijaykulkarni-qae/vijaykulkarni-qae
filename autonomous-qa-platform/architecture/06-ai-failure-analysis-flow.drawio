        <mxCell id="display-apply-fix" value="Optional:&#xa;User can apply&#xa;suggested fix&#xa;to test script" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-display">
          <mxGeometry x="1740" y="80" width="110" height="70" as="geometry" />
        </mxCell>
        
