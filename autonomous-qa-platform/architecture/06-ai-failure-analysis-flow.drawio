        <mxCell id="display-receive-ws" value="Frontend receives:&#xa;'ai:analysis:complete'&#xa;event via WebSocket" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-display">
          <mxGeometry x="1140" y="70" width="130" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="display-show-banner" value="Show Banner/Toast:&#xa;'✨ AI Analysis Complete'&#xa;Click to view insights" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-display">
          <mxGeometry x="1320" y="75" width="140" height="65" as="geometry" />
        </mxCell>
        
        <mxCell id="display-deviation-panel" value="Deviation Panel:&#xa;━━━━━━━━━━━━━━━━&#xa;🔍 Root Cause:&#xa;'{rootCause}'&#xa;&#xa;💡 Suggested Fix:&#xa;'{suggestedFix}'&#xa;&#xa;📊 Confidence: 85%&#xa;⚠️ Severity: Medium&#xa;&#xa;🤖 Analyzed by: Gemini Pro" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=7;align=left;shadow=1;" vertex="1" parent="lane-display">
          <mxGeometry x="1510" y="60" width="180" height="140" as="geometry" />
