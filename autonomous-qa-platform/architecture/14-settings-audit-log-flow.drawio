<mxfile host="app.diagrams.net" modified="2025-12-12T21:00:00.000Z" agent="Autonomous QA - Settings & Audit" version="22.1.0">
  <diagram name="Settings Management & Audit Logging" id="settings-audit-flow">
    <mxGraphModel dx="2200" dy="1500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <mxCell id="title-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a237e;strokeColor=#0d47a1;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="2120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="title" value="Autonomous QA - Settings Management &amp; Audit Logging (Key-Value Store + Compliance)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="400" y="30" width="1400" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="subtitle" value="Category-Based Settings | JSON Schema Validation | Audit All Changes | Compliance Tracking" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="600" y="60" width="1000" height="20" as="geometry" />
        </mxCell>
        
        <!-- Settings Management -->
        <mxCell id="section1" value="═══ PART 1: SETTINGS MANAGEMENT (AppSettings Table) ═══" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#4caf50;" vertex="1" parent="1">
          <mxGeometry x="800" y="110" width="600" height="25" as="geometry" />
        </mxCell>
        
        <!-- Get Settings -->
        <mxCell id="lane-get" value="GET Settings (By Category)" style="swimlane;startSize=30;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="2120" height="180" as="geometry" />
        </mxCell>
        
        <mxCell id="get-request" value="GET /api/settings?&#xa;category=general" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-get">
          <mxGeometry x="80" y="50" width="100" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="get-query" value="SELECT * FROM app_settings&#xa;WHERE category = category&#xa;ORDER BY key" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-get">
          <mxGeometry x="220" y="50" width="130" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="get-parse" value="Parse Values:&#xa;JSON.parse(value)&#xa;&#xa;Types:&#xa;• string&#xa;• number&#xa;• boolean&#xa;• object&#xa;• array" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=6.5;shadow=1;" vertex="1" parent="lane-get">
          <mxGeometry x="390" y="50" width="100" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="get-group" value="Group by Category:&#xa;{&#xa;  general: {...},&#xa;  cleanup: {...},&#xa;  ai: {...},&#xa;  notification: {...}&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#a5d6a7;strokeColor=#2e7d32;fontSize=7;shadow=1;" vertex="1" parent="lane-get">
          <mxGeometry x="530" y="55" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="get-response" value="200 OK&#xa;{settings: {...}}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-get">
          <mxGeometry x="690" y="65" width="90" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="get-categories" value="Setting Categories:&#xa;━━━━━━━━━━━━━━━━&#xa;• general: App name, timezone&#xa;• cleanup: Retention policies&#xa;• ai: Provider config, API keys&#xa;• notification: Webhook URLs&#xa;• execution: Parallel limits&#xa;• report: Allure theme&#xa;• security: CORS, rate limits" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=6.5;align=left;shadow=1;" vertex="1" parent="lane-get">
          <mxGeometry x="850" y="45" width="180" height="90" as="geometry" />
        </mxCell>
        
        <!-- Update Settings -->
        <mxCell id="lane-update" value="UPDATE Setting (Admin Only, with Validation)" style="swimlane;startSize=30;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="2120" height="220" as="geometry" />
        </mxCell>
        
        <mxCell id="update-request" value="PUT /api/settings/:key&#xa;{&#xa;  value: 90,&#xa;  category: 'cleanup'&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-update">
          <mxGeometry x="700" y="50" width="100" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="update-auth" value="1. Check Auth:&#xa;requireRole('admin')&#xa;middleware" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=7;shadow=1;" vertex="1" parent="lane-update">
          <mxGeometry x="840" y="60" width="90" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="update-validate" value="2. Validate Value:&#xa;• Type check&#xa;• Range check&#xa;• Zod schema&#xa;&#xa;Example:&#xa;testRunRetention:&#xa;  number, min: 1, max: 365" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=6;shadow=1;" vertex="1" parent="lane-update">
          <mxGeometry x="970" y="50" width="130" height="85" as="geometry" />
        </mxCell>
        
        <mxCell id="update-old" value="3. Load Old Value:&#xa;SELECT * FROM app_settings&#xa;WHERE key = key&#xa;&#xa;For audit log comparison" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=6.5;shadow=1;" vertex="1" parent="lane-update">
          <mxGeometry x="1140" y="50" width="120" height="85" as="geometry" />
        </mxCell>
        
        <mxCell id="update-upsert" value="4. UPSERT Setting:&#xa;INSERT INTO app_settings&#xa;{key, value, category, updatedBy}&#xa;ON CONFLICT (key)&#xa;DO UPDATE SET&#xa;  value = EXCLUDED.value,&#xa;  updatedBy = EXCLUDED.updatedBy,&#xa;  updatedAt = NOW()" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=5.5;shadow=1;" vertex="1" parent="lane-update">
          <mxGeometry x="1300" y="45" width="150" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="update-audit" value="5. CREATE Audit Log:&#xa;INSERT INTO audit_logs&#xa;{&#xa;  action: 'UPDATE',&#xa;  resource: 'AppSettings',&#xa;  resourceId: key,&#xa;  userId,&#xa;  details: {&#xa;    key,&#xa;    oldValue,&#xa;    newValue&#xa;  }&#xa;}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=5.5;shadow=1;" vertex="1" parent="lane-update">
          <mxGeometry x="1490" y="50" width="130" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="update-response" value="6. Response:&#xa;200 OK&#xa;{&#xa;  setting: {...},&#xa;  auditId&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-update">
          <mxGeometry x="1660" y="65" width="90" height="60" as="geometry" />
        </mxCell>
        
        <!-- Audit Logging Section -->
        <mxCell id="section2" value="═══ PART 2: AUDIT LOGGING (Compliance & Tracking) ═══" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#ff9800;" vertex="1" parent="1">
          <mxGeometry x="800" y="590" width="600" height="25" as="geometry" />
        </mxCell>
        
        <!-- Audit Capture -->
        <mxCell id="lane-audit-capture" value="Audit Log Capture (Automatic on All Mutations)" style="swimlane;startSize=30;fillColor=#fff3e0;strokeColor=#e65100;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="2120" height="260" as="geometry" />
        </mxCell>
        
        <mxCell id="audit-triggers" value="Audit Triggers:&#xa;━━━━━━━━━━━━━━━━&#xa;CREATE: Flow, Folder, User&#xa;UPDATE: Flow, Settings, User&#xa;DELETE: Flow, Folder, TestRun&#xa;EXECUTE: TestRun&#xa;LOGIN: User authentication&#xa;CLONE: Flow, Folder&#xa;MOVE: Flow, Folder&#xa;&#xa;All captured automatically!" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=6.5;align=left;shadow=1;" vertex="1" parent="lane-audit-capture">
          <mxGeometry x="80" y="50" width="150" height="150" as="geometry" />
        </mxCell>
        
        <mxCell id="audit-middleware" value="auditLogger.js&#xa;Middleware captures:&#xa;• req.user.id&#xa;• req.method&#xa;• req.path&#xa;• req.body&#xa;• response status&#xa;• timestamp" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffcc80;strokeColor=#e65100;fontSize=6.5;shadow=1;" vertex="1" parent="lane-audit-capture">
          <mxGeometry x="270" y="60" width="110" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="audit-insert" value="INSERT INTO audit_logs:&#xa;{&#xa;  id: cuid(),&#xa;  action: 'CREATE' | 'UPDATE' | 'DELETE' | 'EXECUTE',&#xa;  resource: 'TestFlow' | 'Folder' | 'User' | 'Settings',&#xa;  resourceId: string,&#xa;  userId: string,&#xa;  username: string,&#xa;  details: JSON,&#xa;  ipAddress: string,&#xa;  userAgent: string,&#xa;  createdAt: NOW()&#xa;}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=5.5;shadow=1;" vertex="1" parent="lane-audit-capture">
          <mxGeometry x="420" y="50" width="160" height="150" as="geometry" />
        </mxCell>
        
        <mxCell id="audit-example" value="Example Audit Log Entry:&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;{&#xa;  id: 'clg...',&#xa;  action: 'UPDATE',&#xa;  resource: 'TestFlow',&#xa;  resourceId: 'flow-123',&#xa;  userId: 'user-456',&#xa;  username: 'john.doe@example.com',&#xa;  details: {&#xa;    field: 'name',&#xa;    oldValue: 'Login Test',&#xa;    newValue: 'Login Test v2',&#xa;    changedFields: ['name', 'description']&#xa;  },&#xa;  ipAddress: '192.168.1.100',&#xa;  userAgent: 'Mozilla/5.0...',&#xa;  createdAt: '2025-12-12T21:00:00Z'&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=5.5;align=left;shadow=1;" vertex="1" parent="lane-audit-capture">
          <mxGeometry x="620" y="50" width="240" height="150" as="geometry" />
        </mxCell>
        
        <mxCell id="audit-indexed" value="Performance Indexes:&#xa;━━━━━━━━━━━━━━━━&#xa;• userId (filter by user)&#xa;• resource (filter by type)&#xa;• createdAt (time-based)&#xa;• action (filter by action)&#xa;&#xa;Enables fast queries:&#xa;'Show all changes by user X'&#xa;'Show all TestFlow updates&#xa; in last 30 days'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=6;align=left;shadow=1;" vertex="1" parent="lane-audit-capture">
          <mxGeometry x="900" y="55" width="160" height="140" as="geometry" />
        </mxCell>
        
        <!-- Audit Query -->
        <mxCell id="lane-audit-query" value="Query Audit Logs (Admin Dashboard)" style="swimlane;startSize=30;fillColor=#f3e5f5;strokeColor=#4a148c;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="910" width="2120" height="240" as="geometry" />
        </mxCell>
        
        <mxCell id="query-request" value="GET /api/audit-logs?&#xa;resource=TestFlow&amp;&#xa;userId=user-456&amp;&#xa;startDate=2025-12-01&amp;&#xa;endDate=2025-12-12&amp;&#xa;action=UPDATE&amp;&#xa;limit=50" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=6;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-audit-query">
          <mxGeometry x="1070" y="50" width="140" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="query-auth" value="1. Auth Check:&#xa;requireRole('admin')" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=7;shadow=1;" vertex="1" parent="lane-audit-query">
          <mxGeometry x="1250" y="65" width="80" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="query-sql" value="2. Build Query:&#xa;SELECT * FROM audit_logs&#xa;WHERE&#xa;  resource = $1&#xa;  AND userId = $2&#xa;  AND createdAt &gt;= $3&#xa;  AND createdAt &lt;= $4&#xa;  AND action = $5&#xa;ORDER BY createdAt DESC&#xa;LIMIT $6" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=5.5;shadow=1;" vertex="1" parent="lane-audit-query">
          <mxGeometry x="1370" y="50" width="140" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="query-enrich" value="3. Enrich with User Data:&#xa;JOIN users ON&#xa;  audit_logs.userId = users.id&#xa;&#xa;Add: username, email" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#4a148c;fontSize=6.5;shadow=1;" vertex="1" parent="lane-audit-query">
          <mxGeometry x="1550" y="60" width="120" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="query-response" value="4. Response:&#xa;200 OK&#xa;{&#xa;  logs: [...],&#xa;  total: 245,&#xa;  page: 1&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-audit-query">
          <mxGeometry x="1710" y="70" width="90" height="65" as="geometry" />
        </mxCell>
        
        <mxCell id="query-ui" value="Admin Dashboard UI:&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;📅 Date Range Picker&#xa;👤 User Filter (dropdown)&#xa;📁 Resource Filter (dropdown)&#xa;⚡ Action Filter (checkboxes)&#xa;🔍 Keyword Search&#xa;📊 Export to CSV&#xa;&#xa;Table Columns:&#xa;• Timestamp | User | Action&#xa;• Resource | Details | IP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=6;align=left;shadow=1;" vertex="1" parent="lane-audit-query">
          <mxGeometry x="80" y="50" width="180" height="140" as="geometry" />
        </mxCell>
        
        <mxCell id="query-compliance" value="Compliance Use Cases:&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;✓ SOC 2: Who changed what?&#xa;✓ GDPR: Track data access&#xa;✓ HIPAA: Access logs&#xa;✓ ISO 27001: Change tracking&#xa;&#xa;Retention: Indefinite&#xa;(or per compliance policy)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=6.5;align=left;shadow=1;" vertex="1" parent="lane-audit-query">
          <mxGeometry x="300" y="60" width="160" height="120" as="geometry" />
        </mxCell>
        
        <!-- Retention & Export -->
        <mxCell id="lane-retention" value="Retention & Export (Compliance)" style="swimlane;startSize=30;fillColor=#e0f2f1;strokeColor=#004d40;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1170" width="2120" height="160" as="geometry" />
        </mxCell>
        
        <mxCell id="ret-policy" value="Retention Policy:&#xa;━━━━━━━━━━━━━━━━&#xa;• Settings: Indefinite&#xa;• Audit Logs: Indefinite&#xa;  (unless policy requires)&#xa;&#xa;Optional: Archive to S3/cold storage after 1 year" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=6.5;align=left;shadow=1;" vertex="1" parent="lane-retention">
          <mxGeometry x="470" y="50" width="180" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="ret-export" value="Export Audit Logs:&#xa;━━━━━━━━━━━━━━━━━━━&#xa;GET /api/audit-logs/export?format=csv&#xa;&#xa;Generates CSV with all fields&#xa;for compliance reporting" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4dd0e1;strokeColor=#006064;fontSize=7;shadow=1;" vertex="1" parent="lane-retention">
          <mxGeometry x="690" y="55" width="180" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="ret-archive" value="Optional Archive:&#xa;━━━━━━━━━━━━━━━━━━━&#xa;Cron job archives logs &gt; 1 year old&#xa;to S3/Azure Blob Storage&#xa;&#xa;Keeps DB performant while&#xa;meeting compliance retention" style="rounded=0;whiteSpace=wrap;html=1;fillColor="#26c6da;strokeColor=#006064;fontSize=6.5;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-retention">
          <mxGeometry x="910" y="55" width="170" height="75" as="geometry" />
        </mxCell>
        
        <!-- Legend -->
        <mxCell id="legend-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="80" y="1380" width="540" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-title" value="LEGEND" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="1385" width="160" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-text" value="Settings: Key-value store with categories, validation, audit on change | Audit Logs: Automatic capture of all mutations (CREATE, UPDATE, DELETE, EXECUTE) | Compliance: SOC 2, GDPR, HIPAA, ISO 27001 ready | Indexed: Fast queries by user, resource, date | Retention: Configurable, with optional cold storage archive | Export: CSV format for compliance reporting&#xa;Colors: Green=Settings/Read | Blue=Query/Response | Orange=Audit/Write | Purple=Admin | Cyan=Export | Red Cylinders=DB" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=6;" vertex="1" parent="1">
          <mxGeometry x="100" y="1410" width="500" height="35" as="geometry" />
        </mxCell>
        
        <!-- Metadata -->
        <mxCell id="metadata-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="1620" y="1380" width="480" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="metadata-title" value="METADATA" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1760" y="1385" width="200" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="metadata-text" value="Endpoints: GET/PUT /api/settings, GET /api/audit-logs, GET /api/audit-logs/export | Services: settingsService.js, auditLogger.js (middleware) | Tables: AppSettings (key, value, category, updatedBy, updatedAt), AuditLog (action, resource, userId, details, createdAt) | Categories: 7 setting categories | Indexes: 4 indexes on audit_logs (userId, resource, createdAt, action) | Pattern: Similar to AWS CloudTrail, Azure Monitor | Last Updated: 2025-12-12 | Complexity: Medium (30+ nodes, 5 lanes)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=5.5;" vertex="1" parent="1">
          <mxGeometry x="1640" y="1410" width="440" height="35" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

