          <mxGeometry x="1270" y="240" width="150" height="100" as="geometry" />
        </mxCell>
        
        <!-- Parallel Branch 4: Check Upload -->
        <mxCell id="check-upload" value="Branch 4:&#xa;Upload file&#xa;required?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-exec-service">
          <mxGeometry x="1460" y="250" width="120" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="upload-check-path" value="Check file exists:&#xa;data/uploads/&#xa;{flowId}/&#xa;{uploadFileName}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=8;shadow=1;" vertex="1" parent="lane-exec-service">
          <mxGeometry x="1620" y="260" width="140" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="upload-missing" value="ERROR:&#xa;Update TestRun&#xa;status: 'failed'&#xa;error: 'Upload missing'&#xa;ROLLBACK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-exec-service">
          <mxGeometry x="1800" y="250" width="130" height="80" as="geometry" />
        </mxCell>
        
        <!-- Join Point -->
        <mxCell id="parallel-join" value="JOIN&#xa;(Wait all branches)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-exec-service">
          <mxGeometry x="1260" y="370" width="140" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="spawn-playwright" value="Spawn Playwright&#xa;child_process.spawn(&#xa;'npx playwright test',&#xa;{browser, headless,&#xa;video: 'on',&#xa;screenshot: 'on'})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00bcd4;strokeColor=#006064;fontSize=8;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-exec-service">
          <mxGeometry x="900" y="360" width="160" height="90" as="geometry" />
