        </mxCell>
        
        <!-- Parallel Branch 2: Create TestRun -->
        <mxCell id="create-testrun" value="Branch 2:&#xa;Prisma Transaction:&#xa;CREATE TestRun&#xa;status: 'running'&#xa;triggeredBy: userId&#xa;startTime: NOW()&#xa;browser, metadata" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;shadow=1;" vertex="1" parent="lane-exec-service">
