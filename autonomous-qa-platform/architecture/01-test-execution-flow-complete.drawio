        <mxCell id="write-temp-file" value="Write test script&#xa;to temp file:&#xa;/tmp/test-{runId}.spec.js&#xa;Include upload file path&#xa;if required" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=8;shadow=1;" vertex="1" parent="lane-exec-service">
