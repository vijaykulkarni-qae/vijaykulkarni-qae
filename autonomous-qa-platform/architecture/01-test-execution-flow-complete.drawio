        <mxCell id="rate-limit" value="1. Rate Limiting&#xa;Check per-user limit&#xa;(30 req/min)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=9;shadow=1;" vertex="1" parent="lane-api">
