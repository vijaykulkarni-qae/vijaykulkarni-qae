        <mxCell id="auth-fail" value="401 Unauthorized&#xa;Clear token&#xa;Redirect to login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
