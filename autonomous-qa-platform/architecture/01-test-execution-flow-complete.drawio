        <mxCell id="audit-log" value="3. auditMiddleware.js&#xa;INSERT INTO audit_logs&#xa;(userId, action='EXECUTE_TEST',&#xa;resource='TestFlow',&#xa;resourceId=flowId,&#xa;ipAddress, userAgent)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#8bc34a;strokeColor=#558b2f;fontSize=8;shadow=1;" vertex="1" parent="lane-api">
