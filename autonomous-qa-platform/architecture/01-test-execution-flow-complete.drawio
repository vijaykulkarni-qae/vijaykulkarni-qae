        </mxCell>
        
        <!-- Swim Lane: Playwright Execution + Step Loop -->
        <mxCell id="lane-playwright" value="Layer 4: Playwright Execution (Child Process) + Step Execution Loop" style="swimlane;startSize=40;fillColor=#e0f2f1;strokeColor=#004d40;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1340" width="2320" height="600" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-start" value="Playwright Process&#xa;Starts (child process)&#xa;PID: {processId}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00bcd4;strokeColor=#006064;fontSize=11;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="720" y="60" width="160" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-browser-launch" value="1. Launch Browser&#xa;chromium.launch({&#xa;  headless: true,&#xa;  args: ['--no-sandbox'],&#xa;  video: {dir: 'videos/'},&#xa;  screenshot: 'on'&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=8;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="920" y="60" width="180" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-context" value="2. Create Context&#xa;browser.newContext({&#xa;  viewport: {width, height},&#xa;  permissions: [...],&#xa;  locale: 'en-US'&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=8;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1130" y="60" width="180" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-page" value="3. Create Page&#xa;page = context.newPage()&#xa;Set default timeout: 30s" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=9;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1340" y="60" width="160" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-step-loop" value="FOR EACH STEP&#xa;in test script&#xa;(i = 1 to N)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=11;fontStyle=1;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1350" y="160" width="140" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-step-counter" value="Calculate Progress:&#xa;progress = (i / N) * 100" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=9;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1530" y="175" width="140" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-execute-step" value="Execute Step {i}:&#xa;• page.goto(url)&#xa;• page.click(selector)&#xa;• page.fill(selector, value)&#xa;• page.press(key)&#xa;• page.waitForSelector(...)&#xa;• expect(locator).toBeVisible()&#xa;Measure duration: startTime → endTime" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff59d;strokeColor=#f57f17;fontSize=8;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1700" y="160" width="200" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-retry" value="Step failed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff5722;strokeColor=#bf360c;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1940" y="180" width="100" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-retry-logic" value="Retry (max 3):&#xa;Wait 1s, 2s, 4s&#xa;(exponential backoff)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="2080" y="190" width="120" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-screenshot" value="Take Screenshot&#xa;page.screenshot({&#xa;  path: '{runId}/step-{i}.png',&#xa;  fullPage: false&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=8;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1730" y="320" width="160" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-step-success" value="Step passed&#xa;after retries?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1520" y="330" width="120" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-step-fail" value="Step FAILED:&#xa;• Capture error stack&#xa;• Take failure screenshot&#xa;• Mark step status: 'failed'&#xa;• errorMessage, selector&#xa;• Continue if non-critical" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1270" y="320" width="140" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-save-step" value="Save to Backend:&#xa;INSERT TestRunStep&#xa;{runId, stepOrder: i,&#xa;stepId, action, selector,&#xa;status: 'passed'/'failed',&#xa;duration, screenshotPath,&#xa;errorMessage}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1050" y="320" width="180" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-emit-progress" value="Backend emits:&#xa;'step:completed'&#xa;{runId, stepOrder: i,&#xa;status, progress: X%,&#xa;elapsedTime}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="830" y="330" width="160" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-critical-fail" value="Critical failure?&#xa;(stop test)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1280" y="450" width="110" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-stop-test" value="STOP Test&#xa;Close browser&#xa;Exit loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d32f2f;strokeColor=#b71c1c;fontSize=9;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="1275" y="540" width="120" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-more-steps" value="i &lt; N ?&#xa;(more steps)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=10;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="650" y="340" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-loop-back" value="i++&#xa;(next step)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=9;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="670" y="450" width="80" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="pw-complete" value="All Steps Complete&#xa;Close browser&#xa;Stop video recording&#xa;Save trace file" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-playwright">
          <mxGeometry x="440" y="345" width="160" height="75" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: AI Analysis (NEW!) -->
        <mxCell id="lane-ai" value="Layer 5: AI Analysis (If Test Failed) - NEW!" style="swimlane;startSize=40;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1960" width="2320" height="360" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-check-fail" value="Test has&#xa;failures?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=11;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="440" y="70" width="120" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-skip" value="Skip AI Analysis&#xa;(all passed)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;strokeColor=#616161;fontSize=10;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="450" y="180" width="100" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-analyze" value="1. globalAIService.js&#xa;analyzeTestFailure({&#xa;  testRun, failedSteps,&#xa;  screenshots, errors&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ba68c8;strokeColor=#4a148c;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="600" y="70" width="160" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-load-provider" value="2. Load Primary&#xa;AI Provider&#xa;(OpenAI/Claude/Gemini)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#7b1fa2;fontSize=9;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="800" y="70" width="140" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-build-context" value="3. Build Context:&#xa;• Failed step details&#xa;• Error messages&#xa;• Screenshots (base64)&#xa;• Element selectors&#xa;• Page URL&#xa;• Knowledge base docs" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#7b1fa2;fontSize=8;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="980" y="60" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-call-api" value="4. Call AI API:&#xa;messages: [&#xa;  {role: 'system', content: 'Analyze...'},&#xa;  {role: 'user', content: context}&#xa;]&#xa;Retry: 3x with exp. backoff" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ab47bc;strokeColor=#6a1b9a;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="1180" y="60" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-parse-response" value="5. Parse AI Response:&#xa;• Root cause&#xa;• Suggested fix&#xa;• Severity (low/medium/high)&#xa;• Affected elements&#xa;• Confidence score" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#7b1fa2;fontSize=8;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="1380" y="60" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-create-deviation" value="6. CREATE Deviation:&#xa;INSERT INTO deviations&#xa;{runId, type: 'test_failure',&#xa;severity, description,&#xa;aiAnalysis: {&#xa;  rootCause, suggestedFix,&#xa;  confidence, provider&#xa;}}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="1580" y="60" width="160" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-track-usage" value="7. Track AI Usage:&#xa;usageTracker.increment({&#xa;  provider, tokens,&#xa;  requestTime, cost&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8bbd0;strokeColor=#880e4f;fontSize=8;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="1780" y="70" width="150" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-emit-event" value="8. WebSocket Emit:&#xa;'ai:analysis:complete'&#xa;{runId, severity,&#xa;rootCause}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="1980" y="80" width="140" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-fallback" value="AI API Failed?&#xa;Retry 3x → Fallback&#xa;to next provider&#xa;→ Skip if all fail" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffab91;strokeColor=#d84315;fontSize=8;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="1185" y="190" width="150" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="ai-circuit-breaker" value="Circuit Breaker:&#xa;5 consecutive fails&#xa;→ Disable provider 5min" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffccbc;strokeColor=#bf360c;fontSize=8;shadow=1;" vertex="1" parent="lane-ai">
          <mxGeometry x="1195" y="280" width="130" height="60" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Post-Execution (Allure Report + Cleanup) -->
        <mxCell id="lane-post-exec" value="Layer 6: Post-Execution (Allure Report + Resource Cleanup)" style="swimlane;startSize=40;fillColor=#fff3e0;strokeColor=#e65100;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="2340" width="2320" height="380" as="geometry" />
        </mxCell>
        
        <mxCell id="post-update-status" value="1. Update TestRun:&#xa;status = passed/failed&#xa;endTime = NOW()&#xa;duration = endTime - startTime&#xa;Calculate:&#xa;totalTests, passedTests,&#xa;failedTests, skippedTests" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;shadow=1;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="450" y="60" width="180" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="post-allure-collect" value="2. Collect Allure Results:&#xa;• allure-results/*.json&#xa;• test-results/&#xa;• screenshots&#xa;• videos&#xa;• trace files" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=8;shadow=1;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="670" y="70" width="160" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="post-allure-generate" value="3. Generate Allure Report:&#xa;allureEnrichmentService&#xa;.generateReport(runId)&#xa;Command:&#xa;'npx allure generate&#xa; allure-results/&#xa; -o allure-reports/{runId}'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffcc80;strokeColor=#e65100;fontSize=7;fontColor=#000000;shadow=1;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="870" y="60" width="180" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="post-allure-enrich" value="4. Enrich Allure Report:&#xa;allureCategoryBuilder.js&#xa;• Add P0/P1/P2 categories&#xa;• Add custom trends&#xa;• Add environment info&#xa;• Add executor details" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#ef6c00;fontSize=8;shadow=1;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1090" y="60" width="170" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="post-save-assets" value="5. Save TestAssets:&#xa;FOR EACH artifact&#xa;INSERT TestAsset&#xa;{runId, type, filePath,&#xa;sizeBytes, width, height,&#xa;duration (video)}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1300" y="60" width="160" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="post-report-url" value="6. Update Report URL:&#xa;TestRun.allureReportUrl&#xa;= '{BACKEND_URL}/&#xa;allure-reports/{runId}/&#xa;index.html'" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1500" y="60" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="post-cleanup-temp" value="7. Cleanup Temp Files:&#xa;• Delete /tmp/test-{runId}.spec.js&#xa;• Delete raw allure-results&#xa;• Keep only final report" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=8;shadow=1;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1700" y="70" width="160" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="post-cleanup-browser" value="8. Resource Cleanup:&#xa;• Close browser (if not closed)&#xa;• Kill Playwright process&#xa;• Release port&#xa;• Free memory&#xa;• Log resource usage" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#cfd8dc;strokeColor=#455a64;fontSize=8;shadow=1;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1900" y="60" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="post-calc-size" value="Calculate Total Size:&#xa;artifactsSizeBytes =&#xa;SUM(TestAssets.sizeBytes)&#xa;Store in TestRun" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffecb3;strokeColor=#ffa000;fontSize=8;shadow=1;" vertex="1" parent="lane-post-exec">
          <mxGeometry x="1310" y="200" width="140" height="80" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Webhook Notification (Fire-and-Forget) -->
        <mxCell id="lane-webhook" value="Layer 7: Webhook Notification (Fire-and-Forget)" style="swimlane;startSize=40;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="2740" width="2320" height="280" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-check-active" value="Query WebhookConfig:&#xa;WHERE isActive = true" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=9;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="460" y="70" width="160" height="80" as="geometry" />
