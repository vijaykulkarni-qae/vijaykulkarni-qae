        <mxCell id="webhook-found" value="Webhooks&#xa;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=11;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="670" y="75" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-skip" value="Skip Notification&#xa;(no webhooks)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;strokeColor=#616161;fontSize=10;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="680" y="170" width="100" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-build-payload" value="webhookPayloadBuilder.js:&#xa;Build payload from&#xa;selected fields:&#xa;testName, status, reportUrl,&#xa;totalTests, passedTests,&#xa;failedTests, duration,&#xa;triggeredBy, executionType" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=8;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="840" y="60" width="180" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-template" value="Apply Template:&#xa;• Google Chat Cards&#xa;• Slack Blocks&#xa;• Generic JSON" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#a5d6a7;strokeColor=#2e7d32;fontSize=9;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="1060" y="75" width="140" height="85" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-post" value="FOR EACH webhook:&#xa;POST to webhook.url&#xa;Timeout: 5 seconds&#xa;(async, non-blocking)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#81c784;strokeColor=#2e7d32;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="1240" y="70" width="160" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-response" value="Response?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#66bb6a;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="1450" y="80" width="100" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-success" value="Log Success:&#xa;Webhook delivered&#xa;to {url}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="1600" y="60" width="120" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-fail" value="Log Error:&#xa;Webhook failed {url}&#xa;Reason: {error}&#xa;DON'T fail test!" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="1600" y="140" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-continue" value="IMPORTANT:&#xa;Webhook failures&#xa;NEVER block&#xa;test execution!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=9;fontStyle=1;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="1770" y="85" width="140" height="70" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Final Response -->
        <mxCell id="lane-response" value="Layer 8: Final Response to Frontend" style="swimlane;startSize=40;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="3040" width="2320" height="240" as="geometry" />
        </mxCell>
        
        <mxCell id="response-emit-complete" value="WebSocket Emit:&#xa;'execution:completed'&#xa;{&#xa;  runId, status, duration,&#xa;  reportUrl, totalTests,&#xa;  passedTests, failedTests,&#xa;  aiAnalysis (if failed)&#xa;}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-response">
          <mxGeometry x="480" y="70" width="180" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="response-audit-log" value="Final Audit Log:&#xa;INSERT audit_logs&#xa;action: 'EXECUTE_TEST'&#xa;status: 'completed'&#xa;duration, outcome" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;shadow=1;" vertex="1" parent="lane-response">
          <mxGeometry x="720" y="70" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="response-http" value="HTTP Response:&#xa;200 OK&#xa;{&#xa;  success: true,&#xa;  runId, status,&#xa;  reportUrl,&#xa;  duration,&#xa;  results: {&#xa;    total, passed, failed&#xa;  }&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976d2;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-response">
          <mxGeometry x="940" y="60" width="180" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="response-update-flow-stats" value="Update TestFlow Stats:&#xa;lastExecutedAt = NOW()&#xa;executionCount++&#xa;successRate = (passed/total)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;shadow=1;" vertex="1" parent="lane-response">
          <mxGeometry x="1180" y="70" width="180" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="response-metrics" value="Log Performance Metrics:&#xa;• Total execution time&#xa;• DB query time&#xa;• Playwright startup time&#xa;• Allure generation time&#xa;• WebSocket latency" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#90caf9;strokeColor=#1565c0;fontSize=8;shadow=1;" vertex="1" parent="lane-response">
          <mxGeometry x="1420" y="70" width="180" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="response-end" value="END&#xa;Execution Complete!" style="ellipse;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=14;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-response">
          <mxGeometry x="1680" y="75" width="140" height="100" as="geometry" />
        </mxCell>
        
        <!-- Legend Section -->
        <mxCell id="legend-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="80" y="3340" width="500" height="380" as="geometry" />
        </mxCell>
        
        <mxCell id="legend-title" value="LEGEND" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
