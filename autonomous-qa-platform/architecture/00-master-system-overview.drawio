        <mxCell id="metrics" value="Production Capacity&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• 14 Major Flows documented with comprehensive diagrams&#xa;• 60+ Backend Services (atomic, modular architecture)&#xa;• 19 Database Tables with 33 indexes + 7 unique constraints&#xa;• 9 AI Providers supported (OpenAI, Claude, Gemini, Groq, Ollama, Mistral, Cohere, LocalAI, Custom)&#xa;• 17 Webhook Fields (field-based payload building for Google Chat, Slack, Teams, Discord)&#xa;• 4 User Roles (user, admin, viewer, executor) with RBAC&#xa;• 7 Setting Categories (general, cleanup, ai, notification, execution, report, security)&#xa;&#xa;Performance Characteristics&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• Test Execution: &lt; 5s overhead (API → Playwright spawn)&#xa;• bcrypt Hashing: ~100ms per password (10 salt rounds)&#xa;• AI Analysis: 2-10s (with retry/fallback)&#xa;• Allure Report Generation: 10-60s (depends on test count)&#xa;• Database Query Performance: &lt; 50ms for indexed queries&#xa;• WebSocket Latency: &lt; 100ms for real-time updates&#xa;• Horizontal Scaling: Tested with 5+ parallel servers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=6;align=left;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1060" y="820" width="860" height="100" as="geometry" />
