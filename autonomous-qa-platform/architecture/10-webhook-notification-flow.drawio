        <mxCell id="payload-google-chat" value="Google Chat Example:&#xa;{&#xa;  cards: [{&#xa;    header: {&#xa;      title: 'Login Test',&#xa;      subtitle: 'Test Complete'&#xa;    },&#xa;    sections: [{&#xa;      widgets: [&#xa;        {keyValue: {&#xa;          topLabel: 'Status',&#xa;          content: '✅ Passed'&#xa;        }},&#xa;        {keyValue: {&#xa;          topLabel: 'Tests',&#xa;          content: '15/15 passed'&#xa;        }}&#xa;      ]&#xa;    }],&#xa;    buttons: [{&#xa;      textButton: {&#xa;        text: 'View Report',&#xa;        onClick: {openLink: {url}}&#xa;      }&#xa;    }]&#xa;  }]&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=5.5;align=left;shadow=1;" vertex="1" parent="lane-payload">
