        <mxCell id="payload-fields" value="17 Available Fields:&#xa;&#xa;Essential (3):&#xa;• testName&#xa;• status&#xa;• reportUrl&#xa;&#xa;Test Results (4):&#xa;• totalTests&#xa;• passedTests&#xa;• failedTests&#xa;• skippedTests&#xa;&#xa;Execution Details (5):&#xa;• duration&#xa;• browser&#xa;• triggeredBy&#xa;• executionType&#xa;• completedAt&#xa;&#xa;Additional (5):&#xa;• startTime, endTime&#xa;• errorMessage&#xa;• tags, flowId, runId" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=6.5;align=left;shadow=1;" vertex="1" parent="lane-payload">
