          <mxGeometry x="270" y="80" width="140" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="payload-build" value="Build Payload Object:&#xa;payload = {}&#xa;&#xa;FOR EACH field:&#xa;  payload[field] =&#xa;    testRun[field]&#xa;&#xa;Example:&#xa;{&#xa;  testName: 'Login Test',&#xa;  status: 'passed',&#xa;  reportUrl: 'https://...',&#xa;  totalTests: 15,&#xa;  passedTests: 15,&#xa;  failedTests: 0&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=6.5;shadow=1;" vertex="1" parent="lane-payload">
          <mxGeometry x="450" y="70" width="160" height="140" as="geometry" />
        </mxCell>
        
