<mxfile host="app.diagrams.net" modified="2025-12-12T14:00:00.000Z" agent="Autonomous QA - Bulk Execution Flow" version="22.1.0">
  <diagram name="Bulk Execution Flow (Tag-Based)" id="bulk-exec-flow">
    <mxGraphModel dx="2400" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Title Section -->
        <mxCell id="title-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a237e;strokeColor=#0d47a1;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="2320" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="title" value="Autonomous QA - Bulk Execution Flow (Tag-Based with Parallel/Sequential Modes)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="500" y="25" width="1400" height="35" as="geometry" />
        </mxCell>
        
        <mxCell id="subtitle" value="End-to-End: Tag Query → Flow Selection → Parallel/Sequential Execution → Individual Tests → Aggregation → Notification" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="400" y="60" width="1600" height="20" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: User/Frontend -->
        <mxCell id="lane-user" value="Layer 1: User / Frontend" style="swimlane;startSize=40;fillColor=#e1f5fe;strokeColor=#01579b;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="2320" height="160" as="geometry" />
        </mxCell>
        
        <mxCell id="user-select-tag" value="1. User selects tag:&#xa;@smoke&#xa;@regression&#xa;@e2e" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=11;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="80" y="55" width="140" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="user-select-mode" value="2. Choose mode:&#xa;• Parallel (faster)&#xa;• Sequential&#xa;  (custom order)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="260" y="55" width="130" height="75" as="geometry" />
        </mxCell>
        
        <mxCell id="user-click-execute" value="3. Click&#xa;'Execute Bulk'&#xa;button" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=11;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="430" y="60" width="110" height="65" as="geometry" />
        </mxCell>
        
        <mxCell id="user-progress-live" value="4. See Live Progress:&#xa;Test 5/25 running&#xa;Passed: 3 | Failed: 1&#xa;Progress: 20%" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="1480" y="60" width="140" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="user-results" value="5. View Results:&#xa;25 tests executed&#xa;22 passed, 3 failed&#xa;Duration: 5m 32s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-user">
          <mxGeometry x="2060" y="60" width="140" height="70" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Backend API -->
        <mxCell id="lane-api" value="Layer 2: Backend API + Validation" style="swimlane;startSize=40;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="2320" height="240" as="geometry" />
        </mxCell>
        
        <mxCell id="api-post" value="POST /api/execute/bulk&#xa;Body: {&#xa;  tag: '@smoke',&#xa;  mode: 'parallel',&#xa;  browser: 'chromium',&#xa;  executionOrder: [...]&#xa;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2196f3;strokeColor=#0d47a1;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="440" y="60" width="160" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="api-auth" value="1. Auth Check&#xa;(JWT validation)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=10;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="640" y="65" width="110" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="api-validate-tag" value="2. Validate Tag:&#xa;• Must start with @&#xa;• Alphanumeric only" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=9;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="790" y="60" width="130" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="api-check-tag" value="Tag&#xa;valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="815" y="150" width="80" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="api-tag-invalid" value="400 Bad Request&#xa;Invalid tag format" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=9;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="950" y="160" width="110" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="api-query-flows" value="3. Query Flows:&#xa;SELECT * FROM test_flows&#xa;WHERE tags @&gt; ARRAY[tag]&#xa;AND status = 'active'&#xa;ORDER BY position" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="1100" y="55" width="150" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="api-check-flows" value="Flows&#xa;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="1135" y="165" width="80" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="api-no-flows" value="404 Not Found&#xa;No flows with tag {tag}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="1260" y="170" width="120" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="api-call-service" value="4. Call Service:&#xa;atomicBulkExecution&#xa;Service.execute({&#xa;  flows, tag, mode,&#xa;  browser, userId&#xa;})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-api">
          <mxGeometry x="1420" y="60" width="150" height="90" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Bulk Execution Service -->
        <mxCell id="lane-bulk-service" value="Layer 3: Bulk Execution Service (atomicBulkExecutionService.js)" style="swimlane;startSize=40;fillColor=#f3e5f5;strokeColor=#4a148c;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="550" width="2320" height="440" as="geometry" />
        </mxCell>
        
        <mxCell id="bulk-start" value="atomicBulkExecution&#xa;Service.execute()&#xa;Found: N flows" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9c27b0;strokeColor=#4a148c;fontSize=10;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-bulk-service">
          <mxGeometry x="1430" y="60" width="130" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="bulk-create-parent" value="1. Create Parent TestRun:&#xa;INSERT TestRun&#xa;{&#xa;  flowId: NULL,&#xa;  triggeredBy: userId,&#xa;  triggerType: 'bulk',&#xa;  tags: [tag],&#xa;  status: 'running',&#xa;  metadata: {&#xa;    mode, totalFlows: N&#xa;  }&#xa;}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-bulk-service">
          <mxGeometry x="1600" y="50" width="170" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="bulk-emit-started" value="2. WebSocket:&#xa;'bulk:started'&#xa;{bulkRunId,&#xa;totalFlows: N,&#xa;mode}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-bulk-service">
          <mxGeometry x="1810" y="70" width="120" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="bulk-mode-check" value="Execution&#xa;mode?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffc107;strokeColor=#ff6f00;fontSize=11;fontStyle=1;shadow=1;" vertex="1" parent="lane-bulk-service">
          <mxGeometry x="1650" y="210" width="110" height="80" as="geometry" />
        </mxCell>
        
        <!-- Parallel Branch -->
        <mxCell id="bulk-parallel" value="PARALLEL MODE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00bcd4;strokeColor=#006064;fontSize=12;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-bulk-service">
          <mxGeometry x="1420" y="320" width="130" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="bulk-parallel-pool" value="Create Worker Pool:&#xa;Max 5 concurrent&#xa;workers (configurable)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4dd0e1;strokeColor=#006064;fontSize=9;shadow=1;" vertex="1" parent="lane-bulk-service">
          <mxGeometry x="1270" y="330" width="130" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="bulk-parallel-assign" value="Assign flows&#xa;to workers:&#xa;Round-robin" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=9;shadow=1;" vertex="1" parent="lane-bulk-service">
          <mxGeometry x="1120" y="335" width="110" height="50" as="geometry" />
        </mxCell>
        
        <!-- Sequential Branch -->
        <mxCell id="bulk-sequential" value="SEQUENTIAL MODE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=12;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-bulk-service">
          <mxGeometry x="1850" y="320" width="140" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="bulk-sequential-queue" value="Create Queue:&#xa;FIFO (First In First Out)&#xa;One at a time" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=9;shadow=1;" vertex="1" parent="lane-bulk-service">
          <mxGeometry x="2030" y="330" width="130" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="bulk-sequential-order" value="Apply custom order:&#xa;executionOrder array&#xa;or default (position)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffcc80;strokeColor=#e65100;fontSize=8;shadow=1;" vertex="1" parent="lane-bulk-service">
          <mxGeometry x="2190" y="335" width="110" height="55" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Individual Test Execution (Loop) -->
        <mxCell id="lane-individual" value="Layer 4: Individual Test Execution (FOR EACH Flow)" style="swimlane;startSize=40;fillColor=#e0f2f1;strokeColor=#004d40;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1010" width="2320" height="480" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-loop" value="FOR EACH flow&#xa;in flows array&#xa;(i = 1 to N)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#00bcd4;strokeColor=#006064;fontSize=10;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="1650" y="60" width="130" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-create-testrun" value="1. Create TestRun:&#xa;INSERT TestRun&#xa;{&#xa;  flowId,&#xa;  triggeredBy: userId,&#xa;  triggerType: 'bulk',&#xa;  status: 'running',&#xa;  metadata: {&#xa;    bulkRunId,&#xa;    position: i/N&#xa;  }&#xa;}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="1480" y="60" width="140" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-bulkrunflow" value="2. CREATE BulkRunFlow:&#xa;INSERT bulk_run_flows&#xa;{&#xa;  bulkRunId,&#xa;  flowId,&#xa;  status: 'running',&#xa;  startTime: NOW()&#xa;}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="1285" y="75" width="160" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-execute" value="3. Execute Test:&#xa;executionService&#xa;.execute(flowId, options)&#xa;&#xa;Full Playwright test:&#xa;• Spawn browser&#xa;• Run steps&#xa;• Generate report&#xa;• Save assets" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#80deea;strokeColor=#006064;fontSize=8;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="1060" y="60" width="180" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-parallel-fork" value="PARALLEL:&#xa;All execute&#xa;simultaneously&#xa;(up to 5 workers)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#4dd0e1;strokeColor=#006064;fontSize=8;fontStyle=1;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="1070" y="210" width="160" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-sequential-one" value="SEQUENTIAL:&#xa;Wait for completion&#xa;before next" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=9;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="1080" y="290" width="140" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-result" value="Test completed:&#xa;Status: passed/failed&#xa;Duration: Xs" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b0bec5;strokeColor=#37474f;fontSize=9;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="850" y="85" width="150" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-update-bulkrunflow" value="4. UPDATE BulkRunFlow:&#xa;UPDATE bulk_run_flows&#xa;SET status = 'completed',&#xa;    endTime = NOW(),&#xa;    duration = X&#xa;WHERE bulkRunId AND flowId" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="660" y="70" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-emit-progress" value="5. WebSocket:&#xa;'bulk:progress'&#xa;{&#xa;  bulkRunId,&#xa;  completed: i,&#xa;  total: N,&#xa;  progress: (i/N)*100,&#xa;  currentFlow,&#xa;  status&#xa;}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="460" y="70" width="160" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-error-handling" value="Test failed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f44336;strokeColor=#c62828;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="695" y="200" width="90" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-continue-on-fail" value="Continue execution&#xa;(don't stop bulk)&#xa;Track failure" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=8;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="665" y="290" width="150" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-more-flows" value="More flows&#xa;to execute?&#xa;(i &lt; N)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="485" y="205" width="110" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-loop-back" value="i++&#xa;Next flow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffeb3b;strokeColor=#f57f17;fontSize=10;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="500" y="295" width="80" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="ind-all-complete" value="All flows executed&#xa;Proceed to aggregation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=#2e7d32;fontSize=10;fontColor=#ffffff;fontStyle=1;shadow=1;" vertex="1" parent="lane-individual">
          <mxGeometry x="280" y="210" width="150" height="60" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Aggregation & Statistics -->
        <mxCell id="lane-aggregation" value="Layer 5: Aggregation &amp; Statistics Calculation" style="swimlane;startSize=40;fillColor=#fff3e0;strokeColor=#e65100;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1510" width="2320" height="340" as="geometry" />
        </mxCell>
        
        <mxCell id="agg-start" value="Aggregation Phase&#xa;All N flows executed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=11;fontStyle=1;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-aggregation">
          <mxGeometry x="280" y="60" width="140" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="agg-query-results" value="1. Query all TestRuns:&#xa;SELECT * FROM test_runs&#xa;WHERE metadata-&gt;&gt;'bulkRunId'&#xa;  = bulkRunId" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=8;shadow=1;" vertex="1" parent="lane-aggregation">
          <mxGeometry x="460" y="55" width="160" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="agg-calculate" value="2. Calculate Statistics:&#xa;totalTests = COUNT(*)&#xa;passedTests = COUNT(&#xa;  WHERE status='passed')&#xa;failedTests = COUNT(&#xa;  WHERE status='failed')&#xa;skippedTests = COUNT(&#xa;  WHERE status='skipped')&#xa;totalDuration = SUM(duration)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#e65100;fontSize=7;shadow=1;" vertex="1" parent="lane-aggregation">
          <mxGeometry x="660" y="50" width="200" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="agg-calculate-avg" value="3. Calculate Averages:&#xa;avgDuration =&#xa;  totalDuration / N&#xa;successRate =&#xa;  (passedTests/totalTests)&#xa;  * 100" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffcc80;strokeColor=#e65100;fontSize=8;shadow=1;" vertex="1" parent="lane-aggregation">
          <mxGeometry x="900" y="60" width="150" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="agg-update-parent" value="4. UPDATE Parent TestRun:&#xa;UPDATE test_runs&#xa;SET&#xa;  status = (failedTests &gt; 0&#xa;    ? 'failed' : 'passed'),&#xa;  endTime = NOW(),&#xa;  duration = totalDuration,&#xa;  totalTests, passedTests,&#xa;  failedTests, skippedTests,&#xa;  metadata = {statistics}&#xa;WHERE id = bulkRunId" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=6;shadow=1;" vertex="1" parent="lane-aggregation">
          <mxGeometry x="1090" y="50" width="180" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="agg-audit-log" value="5. Audit Log:&#xa;INSERT audit_logs&#xa;{&#xa;  userId,&#xa;  action: 'BULK_EXECUTE',&#xa;  resource: 'TestRun',&#xa;  resourceId: bulkRunId,&#xa;  details: {tag, N, stats}&#xa;}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=7;shadow=1;" vertex="1" parent="lane-aggregation">
          <mxGeometry x="1310" y="60" width="160" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="agg-emit-complete" value="6. WebSocket:&#xa;'bulk:completed'&#xa;{&#xa;  bulkRunId,&#xa;  status,&#xa;  totalTests,&#xa;  passedTests,&#xa;  failedTests,&#xa;  duration,&#xa;  successRate&#xa;}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#e65100;fontSize=7;fontColor=#ffffff;shadow=1;" vertex="1" parent="lane-aggregation">
          <mxGeometry x="1520" y="60" width="150" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="agg-summary" value="Summary Report:&#xa;&#xa;Bulk Execution: @smoke&#xa;━━━━━━━━━━━━━━━━━&#xa;Total: 25 tests&#xa;✅ Passed: 22 (88%)&#xa;❌ Failed: 3 (12%)&#xa;Duration: 5m 32s&#xa;Avg: 13.3s per test" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=8;align=left;shadow=1;" vertex="1" parent="lane-aggregation">
          <mxGeometry x="1720" y="60" width="180" height="140" as="geometry" />
        </mxCell>
        
        <!-- Swim Lane: Webhook Notification -->
        <mxCell id="lane-webhook" value="Layer 6: Webhook Notification (Bulk Summary)" style="swimlane;startSize=40;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="1870" width="2320" height="280" as="geometry" />
        </mxCell>
        
        <mxCell id="webhook-query" value="Query Active Webhooks:&#xa;SELECT * FROM webhook_configs&#xa;WHERE isActive = true" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=9;shadow=1;" vertex="1" parent="lane-webhook">
          <mxGeometry x="1730" y="70" width="160" height="80" as="geometry" />
